#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:12
#, php-format
msgid "Locate the <code>%s</code> <strong>Subnets</strong> badge in the machines list."
msgstr "Individuare il badge <code>%s</code> Nell'elenco delle macchine è presente il badge <strong>Subnet</strong>."

