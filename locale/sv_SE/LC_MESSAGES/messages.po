#, php-format
msgid "The device <code>%s</code> is advertising a subnet route. For security reasons, you must opt in to enable this."
msgstr "Enheten <code>%s</code> annonserar en subnät-väg. Av säkerhetsskäl måste du välja att aktivera detta."

#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:12
#, php-format
msgid "Locate the <code>%s</code> <strong>Subnets</strong> badge in the machines list."
msgstr "Leta reda på <code>%s</code> <strong>Subnets-brickan</strong> i maskinlistan."

