msgstr "Αφού συνδεθείτε, επιλέξτε <strong>Επόμενο</strong> για να συνεχίσετε."

#: ../plugins-available/Tailscale/Tailscale.php:52
msgid "Tailscale VPN"
msgstr "Tailscale VPN"

#: ../plugins-available/Tailscale/Tailscale.php:237
#, php-format
msgid "Expected tailscale binary not found at: %s"
msgstr "Το αναμενόμενο δυαδικό αρχείο tailscale δεν βρέθηκε στη διεύθυνση: %s"

#: ../plugins-available/Tailscale/Tailscale.php:238
#, php-format
msgid "Visit the <a href=\"%s\" target=\"_blank\">installation instructions</a> or reinstall the Tailscale plugin."
msgstr "Επισκεφθείτε τις <a href=\"%s\" target=\"_blank\">οδηγίες εγκατάστασης</a> ή επανεγκαταστήστε το πρόσθετο Tailscale."

#: ../plugins-available/Tailscale/Tailscale.php:251
msgid "A Tailscale VPN exit node extension for RaspAP"
msgstr "Μια επέκταση κόμβου εξόδου Tailscale VPN για το RaspAP"

#: ../plugins-available/Tailscale/Tailscale.php:406
