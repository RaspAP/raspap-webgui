msgstr "Χρήση κόμβου εξόδου"

#: ../plugins-available/Tailscale/templates/dialogs/using.php:5
#, php-format
msgid "The device <code>%s</code> is configured to use exit node <code>%s</code>. It has the Tailscale MagicDNS address <code>%s</code>."
msgstr "Η συσκευή <code>%s</code> έχει ρυθμιστεί να χρησιμοποιεί κόμβο εξόδου <code>%s</code>. Έχει τη διεύθυνση Tailscale MagicDNS <code>%s</code>."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:1
msgid "Select an exit node"
msgstr "Επιλέξτε έναν κόμβο εξόδου"

#: ../plugins-available/Tailscale/templates/dialogs/select.php:6
#, php-format
msgid "To use <code>%s</code> as a VPN gateway, configure Tailscale to use an exit node. Tailscale's suggested node is indicated with a star."
msgstr "Για να χρησιμοποιήσετε <code>%s</code> ως πύλη VPN, ρυθμίστε τις παραμέτρους του Tailscale ώστε να χρησιμοποιεί έναν κόμβο εξόδου. Ο προτεινόμενος κόμβος της Tailscale υποδεικνύεται με ένα αστέρι."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:11
#, php-format
msgid "Advertise a <strong>subnet route</strong> for the active <code>%s</code> AP interface"
msgstr "Διαφημίστε μια <strong>διαδρομή υποδικτύου</strong> για το ενεργό <code>%s</code> Διασύνδεση AP"

#: ../plugins-available/Tailscale/templates/dialogs/select.php:13
msgid "Subnet routes let you extend your Tailscale network (known as a tailnet) to include devices that don't or can't run the Tailscale client."
msgstr "Οι διαδρομές υποδικτύου σας επιτρέπουν να επεκτείνετε το δίκτυο Tailscale (γνωστό ως tailnet) ώστε να συμπεριλάβετε συσκευές που δεν εκτελούν ή δεν μπορούν να εκτελέσουν τον πελάτη Tailscale."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:17
msgid "A subnet route acts as a gateway between your tailnet and a physical subnet. The subnet of the active AP interface is preconfigured below; edit if necessary."
msgstr "Μια διαδρομή υποδικτύου λειτουργεί ως πύλη μεταξύ του tailnet και ενός φυσικού υποδικτύου. Το υποδίκτυο της ενεργής διασύνδεσης AP έχει προρυθμιστεί παρακάτω- επεξεργαστείτε το εάν είναι απαραίτητο."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:25
msgid "Route LAN traffic through the exit node."
msgstr "Δρομολόγηση της κυκλοφορίας LAN μέσω του κόμβου εξόδου."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:28
msgid "This will direct all LAN traffic to go through your exit node only."
msgstr "Αυτό θα κατευθύνει όλη την κυκλοφορία LAN να περνάει μόνο από τον κόμβο εξόδου σας."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:35
msgid "Use Tailscale DNS settings (default)."
msgstr "Χρησιμοποιήστε τις ρυθμίσεις DNS της Tailscale (προεπιλογή)."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:38
msgid "Uncheck to use local DNS. This sets <code>--accept-dns=false</code>."
msgstr "Αποεπιλέξτε για να χρησιμοποιήσετε τοπικό DNS. Αυτό θέτει <code>--accept-dns=false</code>."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:45
msgid "Do not use Tailscale subnets (default on Linux)."
msgstr "Μην χρησιμοποιείτε υποδίκτυα Tailscale (προεπιλογή στο Linux)."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:48
msgid "If subnet routes exist for your tailnet, you can route your device's traffic to a subnet router. Enabling this sets <code>--accept-routes=true</code>."
msgstr "Εάν υπάρχουν διαδρομές υποδικτύου για το δίκτυο ουράς σας, μπορείτε να δρομολογήσετε την κυκλοφορία της συσκευής σας σε έναν δρομολογητή υποδικτύου. Η ενεργοποίηση αυτής της λειτουργίας θέτει <code>--accept-routes=true</code>."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:55
msgid "If keys expire for a device, connections to/from the given endpoint will stop working."
msgstr "Εάν λήξουν τα κλειδιά για μια συσκευή, οι συνδέσεις προς/από το συγκεκριμένο τελικό σημείο θα σταματήσουν να λειτουργούν."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:58
msgid "This option uses <code>--force-reauth</code> to renew the keys for this device."
msgstr "Αυτή η επιλογή χρησιμοποιεί <code> την --force-reauth</code> για να ανανεώσει τα κλειδιά για αυτή τη συσκευή."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:63
#, php-format
msgid "Choose <strong>Next</strong> to configure <code>%s</code> to use the selected exit node with these options."
msgstr "Επιλέξτε <strong>Επόμενο</strong> για να ρυθμίσετε τις παραμέτρους <code>%s</code> για τη χρήση του επιλεγμένου κόμβου εξόδου με αυτές τις επιλογές."

#: ../plugins-available/Tailscale/templates/dialogs/select.php:66
msgid "No exit nodes found on your tailnet. Choose <strong>Back</strong> to continue."
msgstr "Δεν βρέθηκαν κόμβοι εξόδου στο δίκτυο ουράς σας. Επιλέξτε <strong>Επιστροφή</strong> για να συνεχίσετε."

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:1
msgid "Configure new exit node"
msgstr "Διαμόρφωση νέου κόμβου εξόδου"

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:3
#, php-format
msgid "For security reasons, you must opt in to enable exit node functionality. The first step is to advertise <code>%s</code> as an exit node in your tailnet. In the next step, you'll allow this device to be an exit node."
msgstr "Για λόγους ασφαλείας, πρέπει να κάνετε opt in για να ενεργοποιήσετε τη λειτουργία του κόμβου εξόδου. Το πρώτο βήμα είναι η διαφήμιση <code>%s</code> ως κόμβος εξόδου στο tailnet σας. Στο επόμενο βήμα, θα επιτρέψετε σε αυτή τη συσκευή να γίνει κόμβος εξόδου."

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:10
#, php-format
msgid "Advertise <code>%s</code> as an exit node"
msgstr "Διαφημιστείτε <code>%s</code> ως κόμβος εξόδου"

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:12
msgid "This effectively configures Tailscale  as a VPN to mask your real location, access region-restricted content, or enhance privacy when connecting from untrusted networks."
msgstr "Αυτό διαμορφώνει αποτελεσματικά το Tailscale ως VPN για να αποκρύψετε την πραγματική σας τοποθεσία, να αποκτήσετε πρόσβαση σε περιεχόμενο περιορισμένης περιοχής ή να ενισχύσετε την ιδιωτικότητα κατά τη σύνδεση από μη αξιόπιστα δίκτυα."

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:16
msgid "This option lets Tailscale know your device is ready to route traffic."
msgstr "Αυτή η επιλογή επιτρέπει στην Tailscale να γνωρίζει ότι η συσκευή σας είναι έτοιμη να δρομολογήσει την κυκλοφορία."

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:23
msgid "Enable optimized UDP throughput"
msgstr "Ενεργοποίηση βελτιστοποιημένης απόδοσης UDP"

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:25
msgid "Recommended for Tailscale exit nodes with Linux 6.2 or later kernels, this uses UDP generic receive offload (GRO) forwarding to reduce CPU overhead."
msgstr "Συνιστάται για κόμβους εξόδου Tailscale με πυρήνες Linux 6.2 ή μεταγενέστερους πυρήνες και χρησιμοποιεί προώθηση UDP generic receive offload (GRO) για να μειώσει την επιβάρυνση της CPU."

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:29
msgid "This option enables transport layer offloads for better performance."
msgstr "Αυτή η επιλογή ενεργοποιεί την εκφόρτωση στρώματος μεταφοράς για καλύτερες επιδόσεις."

#: ../plugins-available/Tailscale/templates/dialogs/exit.php:36
#: ../plugins-available/Tailscale/templates/dialogs/config.php:39
msgid "Choose <strong>Next</strong> to continue."
msgstr "Επιλέξτε <strong>Επόμενο</strong> για να συνεχίσετε."

#: ../plugins-available/Tailscale/templates/dialogs/config.php:1
msgid "Configure device"
msgstr "Διαμόρφωση συσκευής"

#: ../plugins-available/Tailscale/templates/dialogs/config.php:4
#, php-format
msgid "The device <code>%s</code> is connected to your tailnet with the address <code>%s</code>."
msgstr "Η συσκευή <code>%s</code> είναι συνδεδεμένη στο tailnet σας με τη διεύθυνση <code>%s</code>."

#: ../plugins-available/Tailscale/templates/dialogs/config.php:8
msgid "By default, Tailscale only routes traffic between the devices on which it's been installed. You can also route all your public internet traffic by configuring a device on your network as an <strong>exit node</strong>"
msgstr "Από προεπιλογή, το Tailscale δρομολογεί την κυκλοφορία μόνο μεταξύ των συσκευών στις οποίες έχει εγκατασταθεί. Μπορείτε επίσης να δρομολογήσετε όλη τη δημόσια διαδικτυακή κυκλοφορία σας, ρυθμίζοντας μια συσκευή στο δίκτυό σας ως <strong>κόμβο εξόδου</strong>."

#: ../plugins-available/Tailscale/templates/dialogs/config.php:10
msgid "When you route all traffic through an exit node, you're effectively using default routes (0.0.0.0/0, ::/0), similar to how you would if you were using a typical VPN."
msgstr "Όταν δρομολογείτε όλη την κυκλοφορία μέσω ενός κόμβου εξόδου, ουσιαστικά χρησιμοποιείτε προεπιλεγμένες διαδρομές (0.0.0.0.0/0, ::/0), όπως θα κάνατε αν χρησιμοποιούσατε ένα τυπικό VPN."

#: ../plugins-available/Tailscale/templates/dialogs/config.php:14
msgid "You have the option of configuring this device as an exit node, or using another exit node in your tailnet."
msgstr "Έχετε τη δυνατότητα να διαμορφώσετε αυτή τη συσκευή ως κόμβο εξόδου ή να χρησιμοποιήσετε έναν άλλο κόμβο εξόδου στο δίκτυο ουράς σας."

#: ../plugins-available/Tailscale/templates/dialogs/config.php:21
msgid "Select an existing exit node on your tailnet"
msgstr "Επιλέξτε έναν υπάρχοντα κόμβο εξόδου στο tailnet σας"

#: ../plugins-available/Tailscale/templates/dialogs/config.php:23
msgid "This is a typical configuration if you're using this device as a VPN travel router, for example."
msgstr "Αυτή είναι μια τυπική διαμόρφωση αν χρησιμοποιείτε αυτή τη συσκευή ως δρομολογητή ταξιδιού VPN, για παράδειγμα."

#: ../plugins-available/Tailscale/templates/dialogs/config.php:30
msgid "Configure this device as a new exit node"
msgstr "Διαμόρφωση αυτής της συσκευής ως νέου κόμβου εξόδου"

#: ../plugins-available/Tailscale/templates/dialogs/config.php:32
msgid "By configuring this device as an exit node, public internet traffic from devices connected in your tailnet  will be routed through it."
msgstr "Με τη διαμόρφωση αυτής της συσκευής ως κόμβου εξόδου, η δημόσια κυκλοφορία στο διαδίκτυο από συσκευές που είναι συνδεδεμένες στο δίκτυο ουράς σας θα δρομολογείται μέσω αυτής."

#: ../plugins-available/Tailscale/templates/dialogs/active.php:1
msgid "Exit node activated"
msgstr "Ενεργοποίηση κόμβου εξόδου"

#: ../plugins-available/Tailscale/templates/dialogs/active.php:4
#, php-format
msgid "The device <code>%s</code> is connected with the address <code>%s</code> and offers an <strong>exit node</strong>."
msgstr "Η συσκευή <code>%s</code> συνδέεται με τη διεύθυνση <code>%s</code> και προσφέρει έναν <strong>κόμβο εξόδου</strong>."

#: ../plugins-available/Tailscale/templates/dialogs/active.php:13
#, php-format
msgid "See the %s on how to use this exit node with your devices."
msgstr "Ανατρέξτε στη διεύθυνση %s για τον τρόπο χρήσης αυτού του κόμβου εξόδου με τις συσκευές σας."

#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:1
msgid "Approve subnet route"
msgstr "Έγκριση διαδρομής υποδικτύου"

#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:3
#, php-format
msgid "The device <code>%s</code> is advertising a subnet route. For security reasons, you must opt in to enable this."
msgstr "Η συσκευή <code>%s</code> διαφημίζει μια διαδρομή υποδικτύου. Για λόγους ασφαλείας, πρέπει να επιλέξετε να το ενεργοποιήσετε."

#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:12
#, php-format
msgid "Locate the <code>%s</code> <strong>Subnets</strong> badge in the machines list."
msgstr "Εντοπίστε το <code>%s</code> <strong>Subnets</strong> στη λίστα μηχανημάτων."

#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:13
#, php-format
msgid "From the %s icon menu of the device, open the %s panel."
msgstr "Από το μενού εικονιδίων %s της συσκευής, ανοίξτε τον πίνακα %s."

#: ../plugins-available/Tailscale/templates/dialogs/subnet.php:14
msgid "Check the IP range box that corresponds to the subnet route you want to advertise, then select <strong>Save</strong>."
msgstr "Επιλέξτε το πλαίσιο περιοχής IP που αντιστοιχεί στη διαδρομή υποδικτύου που θέλετε να διαφημίσετε και, στη συνέχεια, επιλέξτε <strong>Αποθήκευση</strong>."

#: ../plugins-available/Tailscale/templates/dialogs/auth.php:1
msgid "Login to Tailscale"
msgstr "Σύνδεση στην Tailscale"

#: ../plugins-available/Tailscale/templates/dialogs/auth.php:2
#, php-format
msgid "To connect device %s to your tailnet, choose %s."
msgstr "Για να συνδέσετε τη συσκευή %s στο tailnet σας, επιλέξτε %s."

#: ../plugins-available/Tailscale/templates/dialogs/auth.php:2
#: ../plugins-available/Tailscale/templates/dialogs/auth.php:4
