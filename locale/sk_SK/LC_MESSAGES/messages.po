#: ../templates/adblock/general.php:13
msgid "Enable this option if you want RaspAP to <b>block DNS requests for ads, tracking and other virtual garbage</b>. Blocklists are gathered from multiple, actively maintained sources and automatically updated, cleaned, optimized and moderated on a daily basis."
msgstr "Túto možnosť povoľte, ak chcete, aby RaspAP <b>blokoval požiadavky DNS na reklamy, sledovanie a iný virtuálny odpad</b>. Zoznamy blokovania sa zhromažďujú z viacerých aktívne udržiavaných zdrojov a denne sa automaticky aktualizujú, čistia, optimalizujú a moderujú."

#: ../templates/adblock/general.php:15
msgid "This option adds <code>conf-file</code> and <code>addn-hosts</code> to the dnsmasq configuration."
msgstr "Táto voľba pridá do konfigurácie dnsmasq <code>súbory conf-file</code> a <code>addn-hosts</code>."

