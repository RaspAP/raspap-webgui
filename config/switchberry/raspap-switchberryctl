def require_root() -> None:
    if os.geteuid() != 0:
        raise ControlError("This action must run as root")


def enum_value(value: Any, allowed: set[str], label: str, nullable: bool = False) -> str | None:
    if value is None and nullable:
        return None
    normalized = str(value).strip().upper()
    if nullable and normalized in {"", "NULL", "NONE"}:
        return None
    if normalized not in allowed:
        raise ControlError(f"{label} must be one of: {', '.join(sorted(allowed))}")
    return normalized


def bool_value(value: Any, label: str) -> bool:
    if isinstance(value, bool):
        return value
    if value in (0, 1, "0", "1"):
        return bool(int(value))
    raise ControlError(f"{label} must be a boolean")


def int_value(
    value: Any,
    label: str,
    minimum: int,
    maximum: int,
    nullable: bool = False,
) -> int | None:
    if nullable and value in (None, ""):
        return None
    if isinstance(value, bool):
        raise ControlError(f"{label} must be an integer")
    try:
        number = int(value)
    except (TypeError, ValueError) as exc:
        raise ControlError(f"{label} must be an integer") from exc
    if not minimum <= number <= maximum:
        raise ControlError(f"{label} must be between {minimum} and {maximum}")
    return number


def optional_ip(value: Any, label: str) -> str | None:
    if value in (None, ""):
        return None
    try:
        return str(ipaddress.ip_address(str(value).strip()))
    except ValueError as exc:
        raise ControlError(f"{label} must be a valid IP address") from exc


def validate_dns(value: Any) -> str | None:
    if value in (None, ""):
        return None
    raw = str(value).strip()
    entries = [entry for entry in re.split(r"[\s,]+", raw) if entry]
    if len(entries) > 4:
        raise ControlError("DNS may contain at most four addresses")
    normalized = [str(ipaddress.ip_address(entry)) for entry in entries]
    return ",".join(normalized)


def source_config(raw: Any, label: str, present_key: str) -> dict[str, Any]:
    if not isinstance(raw, dict):
        raise ControlError(f"{label} must be an object")
    present = bool_value(raw.get(present_key, False), f"{label}.{present_key}")
    if not present:
        return {present_key: False, "role": None, "priority": None}
    role = enum_value(raw.get("role"), SOURCE_ROLES, f"{label}.role", nullable=True)
    priority = int_value(raw.get("priority"), f"{label}.priority", 0, 15, nullable=True)
    return {present_key: True, "role": role, "priority": priority}


