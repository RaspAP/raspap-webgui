class ControlError(Exception):
    """A user-facing validation or control error."""


def gpio_expander_device() -> pathlib.Path | None:
    """Locate the TCA6424 without assuming a kernel-assigned I2C bus number."""
    devices = pathlib.Path("/sys/bus/i2c/devices")
    for candidate in sorted(devices.glob("*-0023")):
        if candidate.exists():
            return candidate
    return None


def ksz_ptp_device() -> pathlib.Path | None:
    """Return the PHC registered by the SPI-attached KSZ9567 DSA driver."""
    for candidate in sorted(pathlib.Path("/sys/class/ptp").glob("ptp*")):
        try:
            device = (candidate / "device").resolve(strict=True)
        except OSError:
            continue
        if "spi0.0" in device.parts:
            node = pathlib.Path("/dev") / candidate.name
            if node.exists():
                return node
    return None


def emit(payload: dict[str, Any], exit_code: int = 0) -> None:
    print(json.dumps(payload, separators=(",", ":"), sort_keys=True))
    raise SystemExit(exit_code)


def run(command: list[str], timeout: float = 5.0, cwd: str | None = None) -> dict[str, Any]:
    """Run a fixed argv command and return a structured result."""
    try:
        result = subprocess.run(
            command,
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
            env={**os.environ, "LC_ALL": "C"},
        )
        return {
            "ok": result.returncode == 0,
            "returncode": result.returncode,
            "stdout": result.stdout.strip(),
            "stderr": result.stderr.strip(),
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "ok": False,
            "returncode": 124,
            "stdout": (exc.stdout or "").strip() if isinstance(exc.stdout, str) else "",
            "stderr": f"Command timed out after {timeout:g} seconds",
        }
    except (FileNotFoundError, PermissionError, OSError) as exc:
        return {"ok": False, "returncode": 127, "stdout": "", "stderr": str(exc)}


def port_register(port: int, offset: int) -> int:
    if port not in range(1, 6):
        raise ControlError("Front-panel port must be between 1 and 5")
    return (port << 12) + offset


def ksz_transfer(address: int, payload: bytes, read_length: int = 0) -> bytes:
    """Transfer fixed-width register data with the KSZ9567 over spidev."""
    if not 0 <= address <= 0xFFFFFF:
        raise ControlError("KSZ9567 register address is invalid")
    if not pathlib.Path("/dev/spidev0.0").exists():
        raise ControlError("Direct KSZ9567 SPI access is unavailable in the active switch plane")
    operation = 0x60 if read_length else 0x40
    header = bytes(
        (
            operation | ((address >> 19) & 0x1F),
            (address >> 11) & 0xFF,
            (address >> 3) & 0xFF,
            (address & 0x07) << 5,
        )
    )
    transfer = header + (bytes(read_length) if read_length else payload)
    pattern = "".join(f"\\x{byte:02x}" for byte in transfer)
    result = run(
        [
            "/usr/bin/spidev_test",
            "-D",
            "/dev/spidev0.0",
            "-b",
            "8",
            "-s",
            "1000000",
            "-p",
            pattern,
            "-v",
        ],
        timeout=3,
    )
    if not result["ok"]:
        raise ControlError(result["stderr"] or "KSZ9567 SPI transaction failed")
    if not read_length:
        return b""
    match = re.search(r"^RX\s*\|\s*((?:[0-9A-Fa-f]{2}\s+)+)", result["stdout"], re.MULTILINE)
    if match is None:
        raise ControlError("Unable to parse KSZ9567 SPI response")
    values = bytes(int(item, 16) for item in match.group(1).split())
    if len(values) < 4 + read_length:
        raise ControlError("KSZ9567 SPI response was truncated")
    return values[4 : 4 + read_length]


def ksz_read(address: int, width: int) -> int:
    if width not in {1, 2, 4}:
        raise ControlError("Unsupported KSZ9567 register width")
    return int.from_bytes(ksz_transfer(address, b"", read_length=width), "big")


def ksz_write(address: int, value: int, width: int) -> None:
    if width not in {1, 2, 4} or not 0 <= value < (1 << (width * 8)):
        raise ControlError("Invalid KSZ9567 register value")
    ksz_transfer(address, value.to_bytes(width, "big"))
    observed = ksz_read(address, width)
    if observed != value:
        raise ControlError(
            f"KSZ9567 register 0x{address:04X} verification failed (wrote 0x{value:X}, read 0x{observed:X})"
        )


def first_executable(candidates: tuple[str, ...]) -> str | None:
    for candidate in candidates:
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def read_text(path: str, limit: int = 16_384) -> str:
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as handle:
            return handle.read(limit).strip("\x00\r\n ")
    except OSError:
        return ""


def read_json(path: pathlib.Path) -> dict[str, Any]:
    try:
        with path.open("r", encoding="utf-8") as handle:
            value = json.load(handle)
        return value if isinstance(value, dict) else {}
    except (OSError, json.JSONDecodeError):
        return {}


def detect_switchberry() -> bool:
    software = CONFIG_PATH.is_file() and pathlib.Path("/usr/local/sbin/apply_timing.py").is_file()
    hardware = (
        gpio_expander_device() is not None
        and pathlib.Path("/dev/spidev7.0").exists()
        and pathlib.Path("/dev/ttyAMA5").exists()
        and (pathlib.Path("/dev/spidev0.0").exists() or active_switch_plane() == "DSA")
    )
    return pathlib.Path("/etc/switchberry").is_dir() or software or hardware


def active_switch_plane() -> str:
    """Return the currently booted switch integration plane."""
    if all(pathlib.Path(f"/sys/class/net/{interface}").exists() for interface in FRONT_PORT_INTERFACES.values()):
        return "DSA"
    if pathlib.Path("/dev/spidev0.0").exists():
        return "TC"
    return "UNKNOWN"


def desired_switch_plane(config: dict[str, Any]) -> str:
    return "DSA" if str(config.get("ptp_role", "NONE")).upper() == "BC" else "TC"


def configured_boot_plane() -> str:
    text = read_text(str(BOOT_CONFIG_PATH), limit=262_144)
    active = {
        match.group(1).lower()
        for line in text.splitlines()
        if (match := re.match(r"^\s*dtoverlay\s*=\s*([A-Za-z0-9_-]+)\s*$", line))
    }
    if "switchberrybc-v6" in active or "ksz9567" in active:
        return "DSA"
    if "switchberrytc" in active:
        return "TC"
    return "UNKNOWN"


def get_clock_plane(config: dict[str, Any]) -> dict[str, Any]:
    active = active_switch_plane()
    desired = desired_switch_plane(config)
    boot = configured_boot_plane()
    return {
        "active": active,
        "desired": desired,
        "boot": boot,
        "reboot_required": active != desired or boot != desired,
        "mode": str(config.get("ptp_role", "NONE")).upper(),
    }


def os_release() -> str:
    values: dict[str, str] = {}
    for line in read_text("/etc/os-release").splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            values[key] = value.strip().strip('"')
    return values.get("PRETTY_NAME", "Unknown")


def get_system() -> dict[str, Any]:
    addresses: list[dict[str, Any]] = []
    ip_result = run(["/usr/sbin/ip", "-j", "address", "show"], timeout=3)
    if not ip_result["ok"]:
        ip_result = run(["/sbin/ip", "-j", "address", "show"], timeout=3)
    if ip_result["ok"]:
        try:
            raw = json.loads(ip_result["stdout"])
            for interface in raw:
                addresses.append(
                    {
                        "name": interface.get("ifname", ""),
                        "state": interface.get("operstate", "UNKNOWN"),
                        "mac": interface.get("address", ""),
                        "addresses": [
                            f"{entry.get('local')}/{entry.get('prefixlen')}"
                            for entry in interface.get("addr_info", [])
                            if entry.get("family") in {"inet", "inet6"} and entry.get("local")
                        ],
                    }
                )
        except (json.JSONDecodeError, TypeError):
            pass

    return {
        "hostname": read_text("/etc/hostname") or os.uname().nodename,
        "board_model": read_text("/proc/device-tree/model") or "Unknown",
        "kernel": os.uname().release,
        "operating_system": os_release(),
        "interfaces": addresses,
    }


def get_hardware() -> dict[str, Any]:
    checks = {
        key: {"present": pathlib.Path(path).exists(), "path": path, "description": description}
        for key, (path, description) in HARDWARE_PATHS.items()
    }
    gpio_device = gpio_expander_device()
    checks["gpio_expander"].update(
        {
            "present": gpio_device is not None,
            "path": str(gpio_device) if gpio_device is not None else "/sys/bus/i2c/devices/*-0023",
        }
    )
    dsa_ready = all(pathlib.Path(f"/sys/class/net/{name}").exists() for name in FRONT_PORT_INTERFACES.values())
    checks["switch_spi"].update(
        {
            "present": checks["switch_spi"]["present"] or dsa_ready,
            "path": "/dev/spidev0.0 or lan1-lan5",
            "plane": active_switch_plane(),
        }
    )
    if active_switch_plane() == "DSA":
        phc_device = ksz_ptp_device()
        checks["ptp_clock"].update(
            {
                "present": phc_device is not None,
                "path": str(phc_device) if phc_device is not None else "KSZ9567 DSA PHC unavailable",
            }
        )
    return {
        "checks": checks,
        "device_tree": {
            "mdio": pathlib.Path("/proc/device-tree/mdio/ethernet-phy@0").exists(),
            "gpio_expander": pathlib.Path("/proc/device-tree/i2c@9/gpio@23").exists(),
            "dpll_spi": pathlib.Path("/proc/device-tree/spi_bitbang/spidev@0").exists(),
        },
        "pci": run(["/usr/bin/lspci", "-nn"], timeout=3)["stdout"],
        "usb": run(["/usr/bin/lsusb"], timeout=3)["stdout"],
    }


def get_services(config: dict[str, Any]) -> list[dict[str, Any]]:
    role = str(config.get("ptp_role", "NONE")).upper()
    plane = active_switch_plane()
    expected = {
        "switchberry-sanity.service",
        "switchberry-apply-timing.service",
        "switchberry-dpll-monitor.service",
        "switchberry-ptp-role.service",
        "switchberry-status-web.service",
    }
    if plane == "TC":
        expected.update(
            {
                "switchberry-apply-network.service",
                "switchberry-eth0-fixup.service",
                "switchberry-full-init.service",
                "switchberry-dhcp-watchdog.service",
            }
        )
    if role == "GM":
        expected.update(
            {
                "ts2phc-switchberry.service",
                "ptp4l-switchberry-gm.service",
                "switchberry-phc2sys.service",
                "switchberry-chrony.service",
            }
        )
    elif role == "CLIENT":
        expected.update({"ptp4l-switchberry-client.service", "switchberry-phc2sys.service"})
    elif role == "BC":
        expected.add("ptp4l-switchberry-bc.service")
        if bool(config.get("bc", {}).get("sync_system_clock", False)):
            expected.add("switchberry-bc-phc2sys.service")
    if bool(config.get("gps", {}).get("present", False)):
        expected.update({"gpsd.service", "gpspipe-socat.service"})

    result: list[dict[str, Any]] = []
    for service, description in SERVICES.items():
        state = run(["/usr/bin/systemctl", "is-active", service], timeout=3)
        enabled = run(["/usr/bin/systemctl", "is-enabled", service], timeout=3)
        unit_result = run(["/usr/bin/systemctl", "show", "-p", "Result", "--value", service], timeout=3)
        logs = run(
            ["/usr/bin/journalctl", "-u", service, "-n", "5", "--no-pager", "--output=short"],
            timeout=4,
        )
        active = state["stdout"] or "unknown"
        is_expected = service in expected
        display_state = active
        health = "ok" if active == "active" else "idle"
        if service == "switchberry-ptp-role.service" and active == "inactive" and unit_result["stdout"] == "success":
            display_state = "completed"
            health = "ok"
        elif not is_expected and active == "inactive":
            display_state = "standby"
        elif active == "failed" or (is_expected and active not in {"active", "activating"}):
            health = "error"

        result.append(
            {
                "name": service,
                "description": description,
                "active": active,
                "display_state": display_state,
                "expected": is_expected,
                "health": health,
                "enabled": enabled["stdout"] or "unknown",
                "logs": logs["stdout"],
            }
        )
    return result


def get_ports() -> list[dict[str, Any]]:
    ports: list[dict[str, Any]] = []
    if active_switch_plane() == "DSA":
        for port, interface in FRONT_PORT_INTERFACES.items():
            result = run(["/usr/sbin/ip", "-j", "-details", "link", "show", "dev", interface], timeout=3)
            if not result["ok"]:
                result = run(["/sbin/ip", "-j", "-details", "link", "show", "dev", interface], timeout=3)
            entry: dict[str, Any] = {"port": port, "interface": interface, "state": "Unavailable"}
            try:
                link = json.loads(result["stdout"])[0]
                flags = set(link.get("flags", []))
                link_info = run(["/usr/sbin/ethtool", interface], timeout=3)
                speed_match = re.search(r"^\s*Speed:\s*(.+)$", link_info["stdout"], re.MULTILINE)
                entry.update(
                    {
                        "state": "Up" if "LOWER_UP" in flags else "Down",
                        "enabled": "UP" in flags,
                        "operstate": link.get("operstate", "UNKNOWN"),
                        "speed": speed_match.group(1).strip() if speed_match else "Unknown",
                    }
                )
            except (json.JSONDecodeError, IndexError, TypeError):
                if not result["ok"]:
                    entry["error"] = result["stderr"] or "Unable to query DSA port"
            ports.append(entry)
        return ports

    if pathlib.Path("/dev/spidev0.0").exists():
        for port in range(1, 6):
            try:
                status = ksz_read(port_register(port, 0x13), 1)
                control = ksz_read(port_register(port, 0x100), 2)
                speed_status = ksz_read(port_register(port, 0x30), 1)
                speed_code = (speed_status >> 3) & 0x3
                ports.append(
                    {
                        "port": port,
                        "interface": f"KSZ port {port}",
                        "state": "Up" if status & 0x02 else "Down",
                        "enabled": control != 0x0C00,
                        "speed": {0: "10 Mb/s", 1: "100 Mb/s", 2: "1 Gb/s"}.get(speed_code, "Unknown"),
                    }
                )
            except ControlError as exc:
                ports.append({"port": port, "interface": f"KSZ port {port}", "state": "Unknown", "error": str(exc)})
        return ports

    return [{"port": port, "interface": FRONT_PORT_INTERFACES[port], "state": "Unavailable"} for port in range(1, 6)]


def get_dpll() -> list[dict[str, Any]]:
    dplltool = first_executable(DPLLTOOL_CANDIDATES)
    if dplltool is None:
        return [
            {"channel": 5, "domain": "Frequency", "state": "Unavailable", "combo": ""},
            {"channel": 6, "domain": "Time/1PPS", "state": "Unavailable", "combo": ""},
        ]

    channels: list[dict[str, Any]] = []
    for channel, domain in ((5, "Frequency"), (6, "Time/1PPS")):
        state = run([dplltool, "get-state", str(channel)], timeout=5)
        combo = run([dplltool, "get-combo-slave", str(channel)], timeout=5)
        phase = run([dplltool, "get-phase", str(channel)], timeout=5)
        bandwidth = run([dplltool, "get-loop-bw", str(channel)], timeout=5)
        phase_slope = run([dplltool, "get-psl", str(channel)], timeout=5)
        damping = run([dplltool, "get-damp-factor", str(channel)], timeout=5)
        phase_seconds: float | None = None
        try:
            phase_seconds = float(phase["stdout"])
        except (TypeError, ValueError):
            pass
        bandwidth_match = re.search(r"^(\d+)\s+(uHz|mHz|Hz|kHz)$", bandwidth["stdout"])
        combo_match = re.search(r"Slave:\s*(Enabled|Disabled),\s*Master:\s*(\d+)", combo["stdout"])
        channels.append(
            {
                "channel": channel,
                "domain": domain,
                "state": state["stdout"] or state["stderr"] or "Unknown",
                "combo": combo["stdout"] or combo["stderr"],
                "combo_enabled": combo_match is not None and combo_match.group(1) == "Enabled",
                "combo_master": int(combo_match.group(2)) if combo_match is not None else None,
                "phase_seconds": phase_seconds,
                "phase_nanoseconds": phase_seconds * 1_000_000_000 if phase_seconds is not None else None,
                "loop_bandwidth_value": int(bandwidth_match.group(1)) if bandwidth_match is not None else None,
                "loop_bandwidth_unit": bandwidth_match.group(2) if bandwidth_match is not None else None,
                "phase_slope_limit_ns_per_s": int(phase_slope["stdout"]) if phase_slope["stdout"].isdigit() else None,
                "damping_factor": int(damping["stdout"]) if damping["stdout"].isdigit() else None,
                "available": all(item["ok"] for item in (state, combo, phase, bandwidth, phase_slope, damping)),
            }
        )
    return channels


def format_frequency(frequency_hz: int | None) -> str:
    if frequency_hz is None:
        return "Not configured"
    if frequency_hz == 1:
        return "1 PPS"
    if frequency_hz % 1_000_000 == 0:
        return f"{frequency_hz // 1_000_000} MHz"
    if frequency_hz % 1_000 == 0:
        return f"{frequency_hz // 1_000} kHz"
    return f"{frequency_hz} Hz"


def sma_config_fingerprint(config: dict[str, Any]) -> str:
    """Hash every setting that can alter SMA muxes or DPLL allocation."""
    relevant = {
        "ptp_role": config.get("ptp_role"),
        "gps": config.get("gps"),
        "cm4": config.get("cm4"),
        "synce": config.get("synce"),
        "smas": config.get("smas"),
    }
    encoded = json.dumps(relevant, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(encoded).hexdigest()


def get_sma_status(config: dict[str, Any], dpll: list[dict[str, Any]]) -> dict[str, Any]:
    """Return rear-panel connector routing plus last successful apply state."""
    applied_state = read_json(SMA_APPLIED_STATE_PATH)
    current_fingerprint = sma_config_fingerprint(config)
    applied = applied_state.get("fingerprint") == current_fingerprint
    by_name = {
        str(item.get("name", "")).upper(): item
        for item in config.get("smas", [])
        if isinstance(item, dict)
    }
    channel_state = {int(item.get("channel", -1)): item.get("state", "Unknown") for item in dpll}
    connectors: list[dict[str, Any]] = []

    for hardware_name, hardware in SMA_HARDWARE.items():
        item = by_name.get(hardware_name, {})
        direction = str(item.get("direction", "UNUSED")).upper()
        role = item.get("role")
        priority = item.get("priority")
        frequency = item.get("frequency_hz")
        frequency = frequency if isinstance(frequency, int) and not isinstance(frequency, bool) else None
        route = "DPLL input disabled"
        channel: int | None = None
        actual_frequency: float | None = None
        accuracy_ppm: float | None = None

        if direction == "INPUT":
            route = f"{hardware['rear']} to {hardware['input']}"
            channel = 5 if role == "FREQ_ONLY" else 6
        elif direction == "OUTPUT":
            route = f"{hardware['output']} to {hardware['rear']}"
            if hardware_name == "SMA3":
                channel = 5
                if frequency:
                    divider = max(1, min(0xFFFFFFFF, round(500_000_000 / frequency)))
                    actual_frequency = 500_000_000 / divider
                    accuracy_ppm = ((actual_frequency - frequency) / frequency) * 1_000_000
            else:
                actual_frequency = float(frequency) if frequency is not None else None
                accuracy_ppm = 0.0 if frequency is not None else None
                if hardware_name == "SMA1":
                    channel = 6

        connectors.append(
            {
                "rear": hardware["rear"],
                "hardware": hardware_name,
                "direction": direction,
                "role": role,
                "priority": priority,
                "frequency_hz": frequency,
                "signal": format_frequency(frequency),
                "route": route,
                "shared_with": hardware["shared_with"],
                "output_kind": hardware["output_kind"],
                "channel": channel,
                "lock_state": channel_state.get(channel) if channel is not None else None,
                "actual_frequency_hz": actual_frequency,
                "accuracy_ppm": accuracy_ppm,
                "applied": applied,
            }
        )

    connectors.sort(key=lambda item: int(str(item["rear"]).removeprefix("SMA")))
    return {
        "status": "Applied" if applied else ("Pending apply" if applied_state else "Not yet confirmed"),
        "applied": applied,
        "last_applied_at": applied_state.get("applied_at"),
        "connectors": connectors,
    }


def clockmatrix_config_fingerprint(config: dict[str, Any]) -> str:
    relevant = {
        "ptp_role": config.get("ptp_role"),
        "gps": config.get("gps"),
        "cm4": config.get("cm4"),
        "synce": config.get("synce"),
        "smas": config.get("smas"),
        "clockmatrix": normalize_clockmatrix(config.get("clockmatrix")),
    }
    encoded = json.dumps(relevant, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(encoded).hexdigest()


def get_clockmatrix_status(config: dict[str, Any], dpll: list[dict[str, Any]]) -> dict[str, Any]:
    configured = normalize_clockmatrix(config.get("clockmatrix"))
    configured_by_channel = {item["channel"]: item for item in configured["channels"]}
    applied_state = read_json(CLOCKMATRIX_APPLIED_STATE_PATH)
    applied = applied_state.get("fingerprint") == clockmatrix_config_fingerprint(config)
    channels = []
    for live in dpll:
        item = dict(live)
        item["configured"] = configured_by_channel.get(live.get("channel"), {})
        channels.append(item)

    inputs: list[dict[str, Any]] = []

    def add_input(label: str, source: str, role: str | None, priority: int | None, frequency: int, logical: int) -> None:
        if role in {None, "NONE"}:
            return
        inputs.append(
            {
                "label": label,
                "source": source,
                "role": role,
                "priority": priority,
                "frequency_hz": frequency,
                "signal": format_frequency(frequency),
                "logical_input": logical,
                "physical_input": {1: 0, 2: 8, 3: 1, 4: 9}[logical],
                "channel": 5 if role == "FREQ_ONLY" else 6,
            }
        )

    gps = config.get("gps", {}) if isinstance(config.get("gps"), dict) else {}
    if gps.get("present"):
        add_input("M.2 GNSS", "GPS", gps.get("role"), gps.get("priority"), 1, 3)
    cm4 = config.get("cm4", {}) if isinstance(config.get("cm4"), dict) else {}
    if cm4.get("used_as_source"):
        add_input("CM4 PPS", "CM4", cm4.get("role"), cm4.get("priority"), 1, 2)
    synce = config.get("synce", {}) if isinstance(config.get("synce"), dict) else {}
    if synce.get("used_as_source"):
        add_input(
            f"SyncE port {synce.get('recover_port', '?')}",
            "SYNC_E",
            "FREQ_ONLY",
            synce.get("priority"),
            25_000_000,
            1,
        )
    for sma in config.get("smas", []):
        if not isinstance(sma, dict) or sma.get("direction") != "INPUT":
            continue
        hardware_name = str(sma.get("name", "")).upper()
        hardware = SMA_HARDWARE.get(hardware_name)
        if hardware is None:
            continue
        add_input(
            f"Rear {hardware['rear']}",
            hardware_name,
            sma.get("role"),
            sma.get("priority"),
            int(sma.get("frequency_hz") or (10_000_000 if sma.get("role") == "FREQ_ONLY" else 1)),
            int(hardware_name.removeprefix("SMA")),
        )
    inputs.sort(key=lambda item: (item["channel"], item["priority"] if item["priority"] is not None else 99))
    return {
        "status": "Applied" if applied else ("Pending apply" if applied_state else "Not yet confirmed"),
        "applied": applied,
        "last_applied_at": applied_state.get("applied_at"),
        "device": "Renesas 8A34004 ClockMatrix",
        "channels": channels,
        "inputs": inputs,
    }


