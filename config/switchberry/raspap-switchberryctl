def parse_pmc(output: str, fields: tuple[str, ...]) -> dict[str, str]:
    parsed: dict[str, str] = {}
    for line in output.splitlines():
        stripped = line.strip()
        for field in fields:
            if stripped.startswith(field):
                parts = stripped.split(None, 1)
                if len(parts) == 2:
                    parsed[field] = parts[1]
    return parsed


def parse_pmc_ports(output: str) -> list[dict[str, str]]:
    ports: list[dict[str, str]] = []
    current: dict[str, str] = {}
    for line in output.splitlines():
        stripped = line.strip()
        if stripped.startswith("portIdentity"):
            if current:
                ports.append(current)
            current = {"portIdentity": stripped.split(None, 1)[1] if " " in stripped else ""}
        elif stripped.startswith("portState") and current:
            current["portState"] = stripped.split(None, 1)[1] if " " in stripped else ""
    if current:
        ports.append(current)
    return ports


def get_ptp(config: dict[str, Any]) -> dict[str, Any]:
    role = str(config.get("ptp_role", "NONE")).upper()
    result: dict[str, Any] = {"role": role, "plane": active_switch_plane()}
    if role == "TC":
        result["status"] = "KSZ9567 hardware transparent clock"
        return result
    if role == "NONE":
        result["status"] = "PTP disabled"
        return result
    pmc = shutil.which("pmc") or ("/usr/sbin/pmc" if os.path.isfile("/usr/sbin/pmc") else None)
    candidates = (
        ("/run/ptp4l-switchberry-bc", "/var/run/ptp4l-switchberry-bc")
        if role == "BC"
        else ("/run/ptp4l", "/var/run/ptp4l")
    )
    socket_path = next((path for path in candidates if os.path.exists(path)), None)
    if pmc is None or socket_path is None:
        result["status"] = "PTP management socket is not available"
        return result

    port = run([pmc, "-u", "-s", socket_path, "-b", "0", "GET PORT_DATA_SET"], timeout=4)
    timing = run([pmc, "-u", "-s", socket_path, "-b", "0", "GET TIME_STATUS_NP"], timeout=4)
    result.update(parse_pmc(port["stdout"], ("portState",)))
    result["ports"] = parse_pmc_ports(port["stdout"])
    result.update(parse_pmc(timing["stdout"], ("master_offset", "gmIdentity", "ingress_time")))
    if not port["ok"] and not timing["ok"]:
        result["status"] = port["stderr"] or timing["stderr"] or "Unable to query PTP"
    return result


def get_tc_status() -> dict[str, Any]:
    if active_switch_plane() != "TC":
        return {"available": False, "status": "Direct hardware TC registers are owned by the DSA driver"}
    try:
        message1 = ksz_read(0x514, 2)
        message2 = ksz_read(0x516, 2)
        domain_version = ksz_read(0x518, 2)
        calibrations = []
        for port in range(1, 6):
            raw_asymmetry = ksz_read(port_register(port, 0xC04), 2)
            magnitude = raw_asymmetry & 0x7FFF
            calibrations.append(
                {
                    "port": port,
                    "rx_latency_ns": ksz_read(port_register(port, 0xC00), 2),
                    "tx_latency_ns": ksz_read(port_register(port, 0xC02), 2),
                    "asymmetry_ns": -magnitude if raw_asymmetry & 0x8000 else magnitude,
                }
            )
        return {
            "available": True,
            "enabled": bool(message1 & (1 << 6)),
            "delay_mechanism": "P2P" if message1 & (1 << 2) else "E2E",
            "one_step": bool(message1 & 1),
            "host_role": "MASTER" if message1 & (1 << 1) else "SLAVE",
            "detect_l2": bool(message1 & (1 << 5)),
            "detect_ipv4": bool(message1 & (1 << 4)),
            "detect_ipv6": bool(message1 & (1 << 3)),
            "ieee_802_1as": bool(message1 & (1 << 7)),
            "unicast": bool(message2 & (1 << 12)),
            "alternate_master": bool(message2 & (1 << 11)),
            "priority_queue": bool(message2 & (1 << 10)),
            "domain_check": bool(message2 & (1 << 4)),
            "domain": domain_version & 0xFF,
            "version": (domain_version >> 8) & 0x0F,
            "registers": {"clock": f"0x{ksz_read(0x500, 2):04X}", "message1": f"0x{message1:04X}", "message2": f"0x{message2:04X}"},
            "ports": calibrations,
        }
    except ControlError as exc:
        return {"available": False, "status": str(exc)}


