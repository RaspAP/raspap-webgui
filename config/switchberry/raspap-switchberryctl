    if not isinstance(raw, dict):
        raise ControlError("gnss_receiver must be an object")
    raw_constellations = raw.get("constellations", defaults["constellations"])
    if not isinstance(raw_constellations, dict):
        raise ControlError("gnss_receiver.constellations must be an object")
