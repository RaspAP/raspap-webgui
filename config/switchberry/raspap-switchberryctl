def normalize_tc(raw: Any) -> dict[str, Any]:
    if raw is None:
        raw = {}
    if not isinstance(raw, dict):
        raise ControlError("tc must be an object")
    transports = {
        "l2": bool_value(raw.get("detect_l2", True), "tc.detect_l2"),
        "ipv4": bool_value(raw.get("detect_ipv4", True), "tc.detect_ipv4"),
        "ipv6": bool_value(raw.get("detect_ipv6", True), "tc.detect_ipv6"),
    }
    if not any(transports.values()):
        raise ControlError("Transparent clock mode requires at least one recognized PTP transport")

    raw_ports = raw.get("ports", [])
    by_port: dict[int, Any] = {}
    if raw_ports not in (None, []):
        if not isinstance(raw_ports, list):
            raise ControlError("tc.ports must be an array")
        for item in raw_ports:
            if not isinstance(item, dict):
                raise ControlError("Each transparent-clock port calibration must be an object")
            port = int_value(item.get("port"), "tc.ports.port", 1, 5)
            if port in by_port:
                raise ControlError("Transparent-clock port calibrations must be unique")
            by_port[port] = item

    ports = []
    for port in range(1, 6):
        item = by_port.get(port, {})
        ports.append(
            {
                "port": port,
                "rx_latency_ns": int_value(item.get("rx_latency_ns", 425), f"tc.port{port}.rx_latency_ns", 0, 65535),
                "tx_latency_ns": int_value(item.get("tx_latency_ns", 243), f"tc.port{port}.tx_latency_ns", 0, 65535),
                "asymmetry_ns": int_value(item.get("asymmetry_ns", 0), f"tc.port{port}.asymmetry_ns", -32767, 32767),
            }
        )

    return {
        "delay_mechanism": enum_value(raw.get("delay_mechanism", "E2E"), TC_DELAY_MECHANISMS, "tc.delay_mechanism"),
        "one_step": bool_value(raw.get("one_step", True), "tc.one_step"),
        "detect_l2": transports["l2"],
        "detect_ipv4": transports["ipv4"],
        "detect_ipv6": transports["ipv6"],
        "ieee_802_1as": bool_value(raw.get("ieee_802_1as", False), "tc.ieee_802_1as"),
        "unicast": bool_value(raw.get("unicast", True), "tc.unicast"),
        "alternate_master": bool_value(raw.get("alternate_master", True), "tc.alternate_master"),
        "priority_queue": bool_value(raw.get("priority_queue", True), "tc.priority_queue"),
        "domain_check": bool_value(raw.get("domain_check", False), "tc.domain_check"),
        "domain": int_value(raw.get("domain", 0), "tc.domain", 0, 255),
        "ports": ports,
    }


def normalize_bc(raw: Any, warnings: list[str]) -> dict[str, Any]:
    if raw is None:
        raw = {}
    if not isinstance(raw, dict):
        raise ControlError("bc must be an object")
    profile = enum_value(raw.get("profile", "IEEE1588"), BC_PROFILES, "bc.profile")
    network_transport = enum_value(
        raw.get("network_transport", "L2"), BC_NETWORK_TRANSPORTS, "bc.network_transport"
    )
    delay_mechanism = enum_value(
        raw.get("delay_mechanism", "P2P"), BC_DELAY_MECHANISMS, "bc.delay_mechanism"
    )
    if profile in {"G8275_1", "G8275_2"}:
        raise ControlError(
            "The upstream KSZ9567 DSA driver supports P2P one-step transmission only; "
            "G.8275.1 and G.8275.2 require E2E operation and cannot run as a hardware boundary clock"
        )
    if delay_mechanism != "P2P":
        warnings.append("KSZ9567 hardware boundary-clock mode uses the P2P delay mechanism")
        delay_mechanism = "P2P"
    two_step = bool_value(raw.get("two_step", False), "bc.two_step")
    if two_step:
        warnings.append("KSZ9567 hardware boundary-clock mode uses one-step P2P timestamping")
        two_step = False

    raw_ports = raw.get("ports", [])
    by_port: dict[int, Any] = {}
    if raw_ports not in (None, []):
        if not isinstance(raw_ports, list):
            raise ControlError("bc.ports must be an array")
        for item in raw_ports:
            if not isinstance(item, dict):
                raise ControlError("Each boundary-clock port must be an object")
            port = int_value(item.get("port"), "bc.ports.port", 1, 5)
            if port in by_port:
                raise ControlError("Boundary-clock port definitions must be unique")
            by_port[port] = item

    ports = []
    for port in range(1, 6):
        item = by_port.get(port, {})
        mode = enum_value(item.get("mode", "AUTO"), BC_PORT_MODES, f"bc.port{port}.mode")
        ip_address = optional_ip(item.get("ip_address"), f"bc.port{port}.ip_address")
        cidr = int_value(item.get("cidr"), f"bc.port{port}.cidr", 0, 128, nullable=True)
        gateway = optional_ip(item.get("gateway"), f"bc.port{port}.gateway")
        unicast_master = optional_ip(item.get("unicast_master"), f"bc.port{port}.unicast_master")
        if (ip_address is None) != (cidr is None):
            raise ControlError(f"Boundary-clock port {port} requires both an IP address and CIDR prefix")
        expected_version = 4 if network_transport == "UDPV4" else 6 if network_transport == "UDPV6" else None
        for label, address in (("address", ip_address), ("gateway", gateway), ("unicast master", unicast_master)):
            if address is not None and expected_version is not None and ipaddress.ip_address(address).version != expected_version:
                raise ControlError(f"Boundary-clock port {port} {label} must match the selected IP transport")
        if ip_address is not None:
            maximum_cidr = 32 if ipaddress.ip_address(ip_address).version == 4 else 128
            if cidr is not None and cidr > maximum_cidr:
                raise ControlError(f"Boundary-clock port {port} CIDR prefix must be at most {maximum_cidr}")
        ports.append(
            {
                "port": port,
                "interface": FRONT_PORT_INTERFACES[port],
                "mode": mode,
                "local_priority": int_value(item.get("local_priority", 128), f"bc.port{port}.local_priority", 1, 255),
                "log_announce_interval": int_value(item.get("log_announce_interval", 1), f"bc.port{port}.log_announce_interval", -7, 7),
                "log_sync_interval": int_value(item.get("log_sync_interval", 0), f"bc.port{port}.log_sync_interval", -7, 7),
                "log_min_delay_req_interval": int_value(item.get("log_min_delay_req_interval", 0), f"bc.port{port}.log_min_delay_req_interval", -7, 7),
                "delay_asymmetry_ns": int_value(item.get("delay_asymmetry_ns", 0), f"bc.port{port}.delay_asymmetry_ns", -1_000_000_000, 1_000_000_000),
                "ingress_latency_ns": int_value(item.get("ingress_latency_ns", 0), f"bc.port{port}.ingress_latency_ns", -1_000_000_000, 1_000_000_000),
                "egress_latency_ns": int_value(item.get("egress_latency_ns", 0), f"bc.port{port}.egress_latency_ns", -1_000_000_000, 1_000_000_000),
                "ip_address": ip_address,
                "cidr": cidr,
                "gateway": gateway,
                "unicast_master": unicast_master,
            }
        )

    enabled = [port for port in ports if port["mode"] != "DISABLED"]
    if len(enabled) < 2:
        raise ControlError("Boundary clock mode requires at least two enabled front-panel ports")
    if not any(port["mode"] in {"AUTO", "UPSTREAM"} for port in enabled):
        raise ControlError("Boundary clock mode requires an upstream-capable port")
    if not any(port["mode"] in {"AUTO", "DOWNSTREAM"} for port in enabled):
        raise ControlError("Boundary clock mode requires a downstream-capable port")
    if profile == "G8275_2" and not any(port["unicast_master"] for port in enabled):
        raise ControlError("G.8275.2 requires a unicast master address on at least one enabled port")
    if network_transport in {"UDPV4", "UDPV6"}:
        missing_addresses = [str(port["port"]) for port in enabled if port["ip_address"] is None]
        if missing_addresses:
            raise ControlError(
                "IP boundary-clock transport requires an address and CIDR on enabled port(s): "
                + ", ".join(missing_addresses)
            )

    return {
        "profile": profile,
        "network_transport": network_transport,
        "delay_mechanism": delay_mechanism,
        "domain": int_value(raw.get("domain", 0), "bc.domain", 0, 255),
        "two_step": two_step,
        "priority1": int_value(raw.get("priority1", 128), "bc.priority1", 0, 255),
        "priority2": int_value(raw.get("priority2", 128), "bc.priority2", 0, 255),
        "clock_class": int_value(raw.get("clock_class", 248), "bc.clock_class", 0, 255),
        "local_priority": int_value(raw.get("local_priority", 128), "bc.local_priority", 1, 255),
        "announce_receipt_timeout": int_value(raw.get("announce_receipt_timeout", 3), "bc.announce_receipt_timeout", 2, 255),
        "tx_timestamp_timeout": int_value(raw.get("tx_timestamp_timeout", 1000), "bc.tx_timestamp_timeout", 10, 10000),
        "summary_interval": int_value(raw.get("summary_interval", 0), "bc.summary_interval", -7, 7),
        "clock_servo": enum_value(raw.get("clock_servo", "PI"), BC_CLOCK_SERVOS, "bc.clock_servo"),
        "sync_system_clock": bool_value(raw.get("sync_system_clock", False), "bc.sync_system_clock"),
        "ports": ports,
    }


def normalize_config(data: Any) -> tuple[dict[str, Any], list[str]]:
    if not isinstance(data, dict):
        raise ControlError("Configuration must be a JSON object")

    warnings: list[str] = []
    ptp_role = enum_value(data.get("ptp_role"), PTP_ROLES, "ptp_role")
    clockmatrix = normalize_clockmatrix(data.get("clockmatrix"))
    gnss_receiver = normalize_gnss_receiver(data.get("gnss_receiver"))
    tc = normalize_tc(data.get("tc"))
    bc = normalize_bc(data.get("bc"), warnings)
    if tc["ieee_802_1as"] and (not tc["detect_l2"] or tc["delay_mechanism"] != "P2P"):
        warnings.append("IEEE 802.1AS transparent operation enables Layer 2 detection and P2P delay")
        tc["detect_l2"] = True
        tc["delay_mechanism"] = "P2P"

    gps = source_config(data.get("gps"), "gps", "present")
    cm4 = source_config(data.get("cm4"), "cm4", "used_as_source")
    if gnss_receiver["manage_receiver"] and not gps["present"]:
        raise ControlError("A managed GNSS receiver profile requires the M.2 GNSS timing source to be enabled")

    raw_synce = data.get("synce")
    if not isinstance(raw_synce, dict):
        raise ControlError("synce must be an object")
    synce_used = bool_value(raw_synce.get("used_as_source", False), "synce.used_as_source")
    synce = {
        "used_as_source": synce_used,
        "priority": int_value(raw_synce.get("priority"), "synce.priority", 0, 15, nullable=True)
        if synce_used
        else None,
        "recover_port": int_value(raw_synce.get("recover_port"), "synce.recover_port", 1, 5, nullable=True)
        if synce_used
        else None,
    }
    if synce_used and synce["recover_port"] is None:
        raise ControlError("A front-panel recover port is required when SyncE is enabled")

    raw_smas = data.get("smas")
    if not isinstance(raw_smas, list) or len(raw_smas) != 4:
        raise ControlError("smas must contain exactly SMA1 through SMA4")
    by_name: dict[str, Any] = {}
    for raw_sma in raw_smas:
        if not isinstance(raw_sma, dict):
            raise ControlError("Each SMA entry must be an object")
        name = str(raw_sma.get("name", "")).strip().upper()
        if name not in {"SMA1", "SMA2", "SMA3", "SMA4"} or name in by_name:
            raise ControlError("SMA names must be unique and cover SMA1 through SMA4")
        by_name[name] = raw_sma

    smas: list[dict[str, Any]] = []
    for number in range(1, 5):
        name = f"SMA{number}"
        raw_sma = by_name.get(name)
        if raw_sma is None:
            raise ControlError(f"{name} is missing")
        direction = enum_value(raw_sma.get("direction"), SMA_DIRECTIONS, f"{name}.direction")
        role = enum_value(raw_sma.get("role"), SOURCE_ROLES, f"{name}.role", nullable=True)
        priority = int_value(raw_sma.get("priority"), f"{name}.priority", 0, 15, nullable=True)
        frequency = int_value(
            raw_sma.get("frequency_hz"), f"{name}.frequency_hz", 1, 250_000_000, nullable=True
        )

        if direction == "INPUT":
            if role in {None, "NONE"} or priority is None:
                raise ControlError(f"{name} input requires a role and priority")
            if frequency is None:
                frequency = 10_000_000 if role == "FREQ_ONLY" else 1
                warnings.append(f"{SMA_HARDWARE[name]['rear']} input frequency defaulted to {format_frequency(frequency)}")
        else:
            role = None
            priority = None
        if direction == "OUTPUT" and frequency is None:
            raise ControlError(f"{name} output requires a frequency")
        if direction == "UNUSED":
            frequency = None

        # Hardware SMA4 is the rear-panel User SMA1 and is input-only.
        if name == "SMA4" and direction == "OUTPUT":
            raise ControlError("Rear-panel SMA1 (hardware SMA4) is input-only")
        # Hardware SMA1 shares the CM4 PPS path.
        if name == "SMA1" and direction == "OUTPUT" and ptp_role == "GM":
            raise ControlError("Rear-panel SMA4 cannot output while the CM4 is a PTP grandmaster")
        if name == "SMA3" and direction == "OUTPUT" and frequency == 1:
            warnings.append(
                "Rear-panel SMA2 can synthesize 1 Hz, but Q9/channel 5 does not provide a phase-aligned 1PPS output"
            )

        smas.append(
            {
                "name": name,
                "direction": direction,
                "role": role,
                "priority": priority,
                "frequency_hz": frequency,
            }
        )

    sma_by_name = {item["name"]: item for item in smas}
    if synce["used_as_source"] and sma_by_name["SMA1"]["direction"] == "INPUT":
        raise ControlError("Rear-panel SMA4 input and SyncE share DPLL IN1; disable one of these references")
    if cm4["used_as_source"] and sma_by_name["SMA2"]["direction"] == "INPUT":
        raise ControlError("Rear-panel SMA3 input and the CM4 PPS source share DPLL IN2; disable one of them")
    if (
        gps["present"]
        and gps["role"] is not None
        and sma_by_name["SMA3"]["direction"] == "INPUT"
    ):
        raise ControlError("Rear-panel SMA2 input and M.2 GNSS PPS share DPLL IN3; disable one of them")

    raw_network = data.get("network", {})
    if not isinstance(raw_network, dict):
        raise ControlError("network must be an object")
    mode = enum_value(raw_network.get("mode", "DHCP"), {"DHCP", "STATIC"}, "network.mode")
    network = {
        "mode": mode,
        "ip_address": optional_ip(raw_network.get("ip_address"), "network.ip_address"),
        "cidr": int_value(raw_network.get("cidr"), "network.cidr", 1, 32, nullable=True),
        "gateway": optional_ip(raw_network.get("gateway"), "network.gateway"),
        "dns": validate_dns(raw_network.get("dns")),
    }
    if mode == "STATIC" and (network["ip_address"] is None or network["cidr"] is None):
        raise ControlError("Static Ethernet mode requires an IP address and CIDR prefix")
    if mode == "DHCP":
        network = {"mode": "DHCP", "ip_address": None, "cidr": None, "gateway": None, "dns": None}

    raw_ptp = data.get("ptp", {})
    if not isinstance(raw_ptp, dict):
        raise ControlError("ptp must be an object")
    ptp = {
        "transport": enum_value(raw_ptp.get("transport", "UNICAST"), PTP_TRANSPORTS, "ptp.transport"),
        "master_ip": optional_ip(raw_ptp.get("master_ip"), "ptp.master_ip"),
        "time_traceable": bool_value(raw_ptp.get("time_traceable", True), "ptp.time_traceable"),
    }
    if ptp_role != "CLIENT" or ptp["transport"] != "UNICAST":
        ptp["master_ip"] = None
    elif ptp["master_ip"] is None:
        raise ControlError("PTP client unicast mode requires a master IP address")

    time_sources = []
    for label, source in (("GPS", gps), ("CM4", cm4)):
        enabled = source.get("present", source.get("used_as_source", False))
        if enabled and source.get("role") in {"TIME_ONLY", "TIME_AND_FREQ"}:
            time_sources.append(label)
    time_sources.extend(
        sma["name"]
        for sma in smas
        if sma["direction"] == "INPUT" and sma["role"] in {"TIME_ONLY", "TIME_AND_FREQ"}
    )
    if ptp_role == "GM" and not time_sources:
        raise ControlError("PTP grandmaster mode requires at least one time/1PPS source")

    return (
        {
            "ptp_role": ptp_role,
            "gps": gps,
            "cm4": cm4,
            "synce": synce,
            "smas": smas,
            "clockmatrix": clockmatrix,
            "gnss_receiver": gnss_receiver,
            "network": network,
            "ptp": ptp,
            "tc": tc,
            "bc": bc,
        },
        warnings,
    )


def read_stdin_json() -> Any:
    raw = sys.stdin.buffer.read(MAX_CONFIG_BYTES + 1)
    if len(raw) > MAX_CONFIG_BYTES:
        raise ControlError("Configuration exceeds the 64 KiB limit")
    try:
        return json.loads(raw.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise ControlError(f"Invalid JSON: {exc}") from exc


def backup_config() -> str | None:
    if not CONFIG_PATH.is_file():
        return None
    BACKUP_DIR.mkdir(parents=True, exist_ok=True, mode=0o750)
    timestamp = dt.datetime.now().strftime("%Y%m%dT%H%M%S.%f")
    destination = BACKUP_DIR / f"startup-dpll.{timestamp}.json"
    shutil.copy2(CONFIG_PATH, destination)
    os.chmod(destination, 0o640)
    backups = sorted(BACKUP_DIR.glob("startup-dpll.*.json"), key=lambda path: path.stat().st_mtime)
    for old in backups[:-10]:
        old.unlink(missing_ok=True)
    return str(destination)


def atomic_write_config(config: dict[str, Any]) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temp_path = tempfile.mkstemp(prefix=".startup-dpll.", suffix=".json", dir=str(CONFIG_PATH.parent))
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            json.dump(config, handle, indent=2)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(temp_path, 0o644)
        os.replace(temp_path, CONFIG_PATH)
    finally:
        if os.path.exists(temp_path):
            os.unlink(temp_path)


def atomic_write_text(path: pathlib.Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temp_path = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent))
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(temp_path, mode)
        os.replace(temp_path, path)
    finally:
        if os.path.exists(temp_path):
            os.unlink(temp_path)


def configure_boot_plane(plane: str) -> str | None:
    if plane not in {"TC", "DSA"}:
        raise ControlError("Invalid Switchberry boot plane")
    if not BOOT_CONFIG_PATH.is_file():
        raise ControlError(f"Boot configuration is missing at {BOOT_CONFIG_PATH}")
    original = BOOT_CONFIG_PATH.read_text(encoding="utf-8")
    target_overlay = "switchberrybc-v6" if plane == "DSA" else "switchberrytc"
    alternate_overlay = "switchberrytc" if plane == "DSA" else "switchberrybc-v6"
    managed_names = {"switchberrytc", "switchberrybc-v6", "ksz9567"}
    output: list[str] = []
    inserted = False
    for line in original.splitlines():
        match = re.match(r"^\s*#?\s*dtoverlay\s*=\s*([A-Za-z0-9_-]+)\s*$", line)
        if match and match.group(1).lower() in managed_names:
            if not inserted:
                output.extend((f"dtoverlay={target_overlay}", f"#dtoverlay={alternate_overlay}"))
                inserted = True
            continue
        if match and match.group(1).lower() == "spi0-1cs":
            output.append("#dtoverlay=spi0-1cs" if plane == "DSA" else "dtoverlay=spi0-1cs")
            continue
        output.append(line)
    if not inserted:
        output.extend((f"dtoverlay={target_overlay}", f"#dtoverlay={alternate_overlay}"))
    if plane == "TC" and not any(
        re.match(r"^\s*dtoverlay\s*=\s*spi0-1cs\s*$", line) for line in output
    ):
        output.append("dtoverlay=spi0-1cs")
    updated = "\n".join(output) + "\n"
    if updated == original:
        return None

    timestamp = dt.datetime.now().strftime("%Y%m%dT%H%M%S.%f")
    BACKUP_DIR.mkdir(parents=True, exist_ok=True, mode=0o750)
    backup = BACKUP_DIR / f"boot-config.{timestamp}.txt"
    shutil.copy2(BOOT_CONFIG_PATH, backup)
    os.chmod(backup, 0o640)
    backups = sorted(BACKUP_DIR.glob("boot-config.*.txt"), key=lambda path: path.stat().st_mtime)
    for old in backups[:-10]:
        old.unlink(missing_ok=True)
    atomic_write_text(BOOT_CONFIG_PATH, updated)
    return str(backup)


def generate_bc_config(config: dict[str, Any]) -> str:
    bc = config["bc"]
    transport = {"L2": "L2", "UDPV4": "UDPv4", "UDPV6": "UDPv6"}[bc["network_transport"]]
    delay = bc["delay_mechanism"]
    profile = bc["profile"]
    dataset_comparison = "G.8275.x" if profile in {"G8275_1", "G8275_2"} else "ieee1588"
    lines = [
        "# Generated by raspap-switchberryctl; do not edit.",
        "[global]",
        "clock_type\t\tBC",
        "time_stamping\t\tp2p1step",
        "boundary_clock_jbod\t0",
        f"network_transport\t{transport}",
        f"delay_mechanism\t\t{delay}",
        f"domainNumber\t\t{bc['domain']}",
        f"twoStepFlag\t\t{1 if bc['two_step'] else 0}",
        f"priority1\t\t{bc['priority1']}",
        f"priority2\t\t{bc['priority2']}",
        f"clockClass\t\t{bc['clock_class']}",
        f"dataset_comparison\t{dataset_comparison}",
        f"G.8275.defaultDS.localPriority\t{bc['local_priority']}",
        f"announceReceiptTimeout\t{bc['announce_receipt_timeout']}",
        f"tx_timestamp_timeout\t{bc['tx_timestamp_timeout']}",
        f"summary_interval\t{bc['summary_interval']}",
        f"clock_servo\t\t{bc['clock_servo'].lower()}",
        "free_running\t\t0",
        "uds_address\t\t/run/ptp4l-switchberry-bc",
        "uds_ro_address\t\t/run/ptp4l-switchberry-bc-ro",
        "uds_file_mode\t\t0660",
        "uds_ro_file_mode\t0666",
        "use_syslog\t\t1",
        "verbose\t\t0",
    ]
    if profile == "G8275_2":
        lines.extend(("inhibit_multicast_service\t1", "unicast_listen\t\t1", "unicast_req_duration\t60"))

    table_id = 1
    table_by_port: dict[int, int] = {}
    for port in bc["ports"]:
        if (
            bc["network_transport"] in {"UDPV4", "UDPV6"}
            and port["mode"] != "DISABLED"
            and port["unicast_master"]
        ):
            table_by_port[port["port"]] = table_id
            lines.extend(
                (
                    "",
                    "[unicast_master_table]",
                    f"table_id\t\t\t{table_id}",
                    "logQueryInterval\t0",
                    f"{'UDPv6' if bc['network_transport'] == 'UDPV6' else 'UDPv4'}\t\t\t{port['unicast_master']}",
                )
            )
            table_id += 1

    for port in bc["ports"]:
        if port["mode"] == "DISABLED":
            continue
        lines.extend(
            (
                "",
                f"[{port['interface']}]",
                f"G.8275.portDS.localPriority\t{port['local_priority']}",
                f"logAnnounceInterval\t{port['log_announce_interval']}",
                f"logSyncInterval\t\t{port['log_sync_interval']}",
                f"logMinDelayReqInterval\t{port['log_min_delay_req_interval']}",
                f"delayAsymmetry\t\t{port['delay_asymmetry_ns']}",
                f"ingressLatency\t\t{port['ingress_latency_ns']}",
                f"egressLatency\t\t{port['egress_latency_ns']}",
            )
        )
        if port["mode"] == "UPSTREAM":
            lines.append("clientOnly\t\t1")
        elif port["mode"] == "DOWNSTREAM":
            lines.append("serverOnly\t\t1")
        if port["port"] in table_by_port:
            lines.append(f"unicast_master_table\t{table_by_port[port['port']]}")
    return "\n".join(lines) + "\n"


def apply_tc_config(config: dict[str, Any], enabled: bool = True) -> None:
    tc = config["tc"]
    role = config["ptp_role"]
    message1 = 0
    if enabled:
        message1 |= 1 << 6
    if tc["ieee_802_1as"]:
        message1 |= 1 << 7
    if tc["detect_l2"]:
        message1 |= 1 << 5
    if tc["detect_ipv4"]:
        message1 |= 1 << 4
    if tc["detect_ipv6"]:
        message1 |= 1 << 3
    if tc["delay_mechanism"] == "P2P":
        message1 |= 1 << 2
    if role == "GM":
        message1 |= 1 << 1
    if tc["one_step"]:
        message1 |= 1

    message2 = 0
    if tc["unicast"]:
        message2 |= 1 << 12
    if tc["alternate_master"]:
        message2 |= 1 << 11
    if tc["priority_queue"]:
        message2 |= 1 << 10
    if tc["domain_check"]:
        message2 |= 1 << 4
    if tc["detect_ipv4"]:
        message2 |= 1 << 2

    ksz_write(0x500, 0x8002, 2)
    ksz_write(0x514, message1, 2)
    ksz_write(0x516, message2, 2)
    ksz_write(0x518, (2 << 8) | tc["domain"], 2)
    for port in tc["ports"]:
        number = port["port"]
        asymmetry = abs(port["asymmetry_ns"]) | (0x8000 if port["asymmetry_ns"] < 0 else 0)
        ksz_write(port_register(number, 0xC00), port["rx_latency_ns"], 2)
        ksz_write(port_register(number, 0xC02), port["tx_latency_ns"], 2)
        ksz_write(port_register(number, 0xC04), asymmetry, 2)


def queue_apply() -> str:
    if not os.path.isfile(CONTROL_PATH):
        raise ControlError(f"Installed controller not found at {CONTROL_PATH}")
    unit = f"raspap-switchberry-apply-{int(time.time())}"
    result = run(
        [
            "/usr/bin/systemd-run",
            f"--unit={unit}",
            "--collect",
            "--no-block",
            "--property=Type=oneshot",
            CONTROL_PATH,
            "_apply",
        ],
        timeout=8,
    )
    if not result["ok"]:
        raise ControlError(result["stderr"] or result["stdout"] or "Unable to queue timing stack apply")
    return unit


def systemctl(action: str, service: str, required: bool = True, timeout: float = 30) -> None:
    if action not in {"start", "stop", "restart"} or service not in SERVICES:
        raise ControlError("Invalid Switchberry service action")
    result = run(["/usr/bin/systemctl", action, service], timeout=timeout)
    if required and not result["ok"]:
        raise ControlError(result["stderr"] or result["stdout"] or f"Unable to {action} {service}")


def stop_ptp_services() -> None:
    for service in (
        "ptp4l-switchberry-gm.service",
        "ptp4l-switchberry-client.service",
        "ptp4l-switchberry-bc.service",
        "switchberry-phc2sys.service",
        "switchberry-bc-phc2sys.service",
        "switchberry-chrony.service",
        "ts2phc-switchberry.service",
    ):
        systemctl("stop", service, required=False)
    run(["/usr/bin/systemctl", "stop", "switchberry-cm4-pps-monitor.service"], timeout=20)


def prepare_bc_ports(config: dict[str, Any]) -> None:
    previous = read_json(BC_ADDRESS_STATE_PATH)
    for item in previous.get("addresses", []):
        if not isinstance(item, dict):
            continue
        interface = str(item.get("interface", ""))
        address = str(item.get("address", ""))
        route = str(item.get("route", ""))
        gateway = str(item.get("gateway", ""))
        if interface in FRONT_PORT_INTERFACES.values() and address:
            run(["/usr/sbin/ip", "address", "del", address, "dev", interface], timeout=4)
        if interface in FRONT_PORT_INTERFACES.values() and route and gateway:
            run(["/usr/sbin/ip", "route", "del", route, "via", gateway, "dev", interface], timeout=4)

    applied: list[dict[str, str]] = []
    ip_transport = config["bc"]["network_transport"] in {"UDPV4", "UDPV6"}
    for port in config["bc"]["ports"]:
        interface = port["interface"]
        if not pathlib.Path(f"/sys/class/net/{interface}").exists():
            raise ControlError(f"Boundary-clock interface {interface} is unavailable; reboot into the DSA plane")
        if os.path.isfile("/usr/bin/nmcli"):
            run(["/usr/bin/nmcli", "device", "set", interface, "managed", "no"], timeout=5)
        state = "down" if port["mode"] == "DISABLED" else "up"
        result = run(["/usr/sbin/ip", "link", "set", "dev", interface, state], timeout=4)
        if not result["ok"]:
            result = run(["/sbin/ip", "link", "set", "dev", interface, state], timeout=4)
        if not result["ok"]:
            raise ControlError(result["stderr"] or f"Unable to set {interface} {state}")
        if state == "up" and ip_transport:
            address = f"{port['ip_address']}/{port['cidr']}"
            result = run(["/usr/sbin/ip", "address", "replace", address, "dev", interface], timeout=4)
            if not result["ok"]:
                raise ControlError(result["stderr"] or f"Unable to configure {address} on {interface}")
            record = {"interface": interface, "address": address, "route": "", "gateway": ""}
            if port["unicast_master"] and port["gateway"]:
                route = f"{port['unicast_master']}/{'32' if ipaddress.ip_address(port['unicast_master']).version == 4 else '128'}"
                result = run(
                    ["/usr/sbin/ip", "route", "replace", route, "via", port["gateway"], "dev", interface],
                    timeout=4,
                )
                if not result["ok"]:
                    raise ControlError(result["stderr"] or f"Unable to route {route} through {interface}")
                record.update({"route": route, "gateway": port["gateway"]})
            applied.append(record)
    atomic_write_text(BC_ADDRESS_STATE_PATH, json.dumps({"addresses": applied}, indent=2) + "\n", mode=0o600)


def command_role_apply() -> None:
    require_root()
    config, _ = normalize_config(read_json(CONFIG_PATH))
    role = config["ptp_role"]
    plane = active_switch_plane()
    wanted = desired_switch_plane(config)
    if plane != wanted:
        raise ControlError(f"Mode {role} requires the {wanted} switch plane; reboot is required")

    stop_ptp_services()
    if role == "BC":
        prepare_bc_ports(config)
        atomic_write_text(BC_CONFIG_PATH, generate_bc_config(config), mode=0o640)
        systemctl("start", "ptp4l-switchberry-bc.service")
        if config["bc"]["sync_system_clock"]:
            systemctl("start", "switchberry-bc-phc2sys.service")
        return

    if role == "NONE":
        apply_tc_config(config, enabled=False)
        return

    apply_tc_config(config, enabled=True)
    if role == "TC":
        return
    generator = run(
        [
            "/usr/bin/python3",
            "/usr/local/sbin/generate_ptp_conf.py",
            "--config",
            str(CONFIG_PATH),
            "--outdir",
            "/etc/switchberry",
        ],
        timeout=10,
    )
    if not generator["ok"]:
        raise ControlError(generator["stderr"] or generator["stdout"] or "Unable to generate the ptp4l profile")
    if role == "GM":
        systemctl("start", "gpspipe-socat.service", required=False)
        systemctl("start", "ts2phc-switchberry.service")
        systemctl("start", "ptp4l-switchberry-gm.service")
        systemctl("start", "switchberry-phc2sys.service")
        systemctl("start", "switchberry-chrony.service")
        return
    if role == "CLIENT":
        systemctl("start", "ptp4l-switchberry-client.service")
        run(["/usr/bin/systemctl", "start", "switchberry-cm4-pps-monitor.service"], timeout=20)
        systemctl("start", "switchberry-phc2sys.service")


def command_apply_timing() -> None:
    """Run the board timing utility with a role it understands.

    The original Switchberry utility predates transparent- and boundary-clock
    roles and accepts only GM, CLIENT, and NONE. Boundary-clock hardware uses
    the client-safe CM4/DPLL routing; a standalone transparent clock uses the
    neutral routing. The authoritative configuration remains unchanged.
    """
    require_root()
    config, _ = normalize_config(read_json(CONFIG_PATH))
    compatibility = json.loads(json.dumps(config))
    compatibility["ptp_role"] = {"BC": "CLIENT", "TC": "NONE"}.get(
        config["ptp_role"], config["ptp_role"]
    )
    atomic_write_text(TIMING_COMPAT_PATH, json.dumps(compatibility, indent=2) + "\n", mode=0o600)
    result = run(
        [
            "/usr/bin/python3",
            "/usr/local/sbin/apply_timing.py",
            "-c",
            str(TIMING_COMPAT_PATH),
        ],
        timeout=180,
    )
    if result["stdout"]:
        print(result["stdout"], end="")
    if result["stderr"]:
        print(result["stderr"], end="", file=sys.stderr)
    if not result["ok"]:
        raise ControlError("Switchberry timing utility failed")
    apply_gnss_receiver_settings(config)
    apply_clockmatrix_overrides(config)
    atomic_write_text(
        SMA_APPLIED_STATE_PATH,
        json.dumps(
            {
                "applied_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                "fingerprint": sma_config_fingerprint(config),
                "configured_role": config["ptp_role"],
                "board_timing_role": compatibility["ptp_role"],
                "smas": config["smas"],
            },
            indent=2,
        )
        + "\n",
        mode=0o640,
    )
    atomic_write_text(
        CLOCKMATRIX_APPLIED_STATE_PATH,
        json.dumps(
            {
                "applied_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                "fingerprint": clockmatrix_config_fingerprint(config),
                "clockmatrix": config["clockmatrix"],
            },
            indent=2,
        )
        + "\n",
        mode=0o640,
    )
    atomic_write_text(
        GNSS_APPLIED_STATE_PATH,
        json.dumps(
            {
                "applied_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                "fingerprint": gnss_config_fingerprint(config),
                "gps": config["gps"],
                "gnss_receiver": config["gnss_receiver"],
            },
            indent=2,
        )
        + "\n",
        mode=0o640,
    )


def run_dpll_control(dplltool: str, arguments: list[str], description: str) -> str:
    result = run([dplltool, *arguments], timeout=10)
    if not result["ok"]:
        raise ControlError(result["stderr"] or result["stdout"] or f"Unable to {description}")
    return result["stdout"]


def apply_gnss_receiver_settings(config: dict[str, Any]) -> None:
    settings = config["gnss_receiver"]
    if not settings["manage_receiver"]:
        return
    if not config["gps"]["present"]:
        raise ControlError("Enable the M.2 GNSS timing source before applying a managed receiver profile")
    ubxtool = shutil.which("ubxtool")
    if ubxtool is None:
        raise ControlError("u-blox receiver control utility is unavailable")
    values = {
        "CFG-NAVSPG-DYNMODEL": GNSS_DYNAMIC_MODELS[settings["dynamic_model"]],
        "CFG-RATE-MEAS": settings["measurement_rate_ms"],
        "CFG-RATE-NAV": 1,
        "CFG-NAVSPG-INFIL_MINELEV": settings["minimum_elevation_deg"],
    }
    values.update(
        {
            key: 1 if settings["constellations"][name] else 0
            for name, key in GNSS_CONSTELLATION_KEYS.items()
        }
    )
    command = [ubxtool, "-P", UBLOX_PROTOCOL_VERSION]
    for key, value in values.items():
        # RAM is authoritative at runtime. The normalized profile is reapplied
        # at every boot without repeatedly writing receiver flash.
        command.extend(("-z", f"{key},{value},1"))
    command.extend(("-w", "2", "-v", "1"))
    result = run(command, timeout=6)
    if not result["ok"] or "UBX-ACK-NAK" in result["stdout"]:
        raise ControlError(result["stderr"] or result["stdout"] or "Unable to configure the GNSS receiver")


def apply_clockmatrix_overrides(config: dict[str, Any]) -> None:
    dplltool = first_executable(DPLLTOOL_CANDIDATES)
    if dplltool is None:
        raise ControlError("ClockMatrix control utility is unavailable")
    for item in config["clockmatrix"]["channels"]:
        channel = item["channel"]
        other = 6 if channel == 5 else 5
        if item["override_tuning"]:
            run_dpll_control(
                dplltool,
                ["set-loop-bw", str(channel), str(item["loop_bandwidth_value"]), item["loop_bandwidth_unit"]],
                f"set channel {channel} loop bandwidth",
            )
            run_dpll_control(
                dplltool,
                ["set-psl", str(channel), str(item["phase_slope_limit_ns_per_s"])],
                f"set channel {channel} phase-slope limit",
            )
            run_dpll_control(
                dplltool,
                ["set-damp-factor", str(channel), str(item["damping_factor"])],
                f"set channel {channel} damping factor",
            )
        if item["combo_mode"] == "INDEPENDENT":
            run_dpll_control(
                dplltool,
                ["set-combo-slave", str(channel), str(other), "disable"],
                f"make channel {channel} independent",
            )
        elif item["combo_mode"] == "FOLLOW_OTHER":
            run_dpll_control(
                dplltool,
                ["set-combo-slave", str(channel), str(other), "enable"],
                f"make channel {channel} follow channel {other}",
            )


def command_clockmatrix(channel: int, action: str) -> None:
    require_root()
    if channel not in {5, 6} or action not in CLOCKMATRIX_ACTIONS:
        raise ControlError("Invalid ClockMatrix channel action")
    dplltool = first_executable(DPLLTOOL_CANDIDATES)
    if dplltool is None:
        raise ControlError("ClockMatrix control utility is unavailable")
    if action == "reacquire":
        run_dpll_control(dplltool, ["set_oper_state", str(channel), "FREERUN"], "start channel reacquisition")
        time.sleep(0.3)
        run_dpll_control(dplltool, ["set_oper_state", str(channel), "NORMAL"], "complete channel reacquisition")
        message = f"ClockMatrix channel {channel} reacquisition requested"
    else:
        state = CLOCKMATRIX_OPERATING_STATES[action]
        run_dpll_control(dplltool, ["set_oper_state", str(channel), state], f"set channel {channel} {state}")
        message = f"ClockMatrix channel {channel} operating state set to {state}"
    time.sleep(0.1)
    observed = run([dplltool, "get-state", str(channel)], timeout=5)
    emit(
        {
            "ok": True,
            "message": message,
            "channel": channel,
            "action": action,
            "observed_state": observed["stdout"] or "Unknown",
        }
    )


def command_gnss(action: str) -> None:
    require_root()
    if action not in GNSS_ACTIONS:
        raise ControlError("Invalid GNSS receiver action")
    if action == "restart":
        systemctl("restart", "gpsd.service")
        systemctl("restart", "gpspipe-socat.service", required=False)
        emit({"ok": True, "action": action, "message": "GNSS data services restarted"})

    ubxtool = shutil.which("ubxtool")
    if ubxtool is None:
        raise ControlError("u-blox receiver control utility is unavailable")
    preset = {"hotstart": "HOTBOOT", "warmstart": "WARMBOOT", "coldstart": "COLDBOOT"}[action]
    result = run([ubxtool, "-P", UBLOX_PROTOCOL_VERSION, "-p", preset, "-w", "1"], timeout=5)
    if not result["ok"] or "UBX-ACK-NAK" in result["stdout"]:
        raise ControlError(result["stderr"] or result["stdout"] or f"Unable to perform GNSS {action}")
    time.sleep(2)
    config, _ = normalize_config(read_json(CONFIG_PATH))
    if config["gnss_receiver"]["manage_receiver"]:
        apply_gnss_receiver_settings(config)
    labels = {"hotstart": "Hot start", "warmstart": "Warm start", "coldstart": "Cold start"}
    emit({"ok": True, "action": action, "message": f"GNSS receiver {labels[action].lower()} requested"})


def command_eth0_fixup() -> None:
    """Recover the external CM4 PHY after returning from the DSA plane."""
    require_root()
    if active_switch_plane() != "TC":
        raise SystemExit(1)
    # bcmgenet can retry the MDIO probe roughly 30 seconds after eth0 appears.
    # Give that normal retry a chance before consuming a recovery attempt.
    for _attempt in range(36):
        if pathlib.Path("/sys/class/net/eth0/phydev").exists():
            if ETH0_FIX_COUNTER_PATH.exists():
                atomic_write_text(ETH0_FIX_COUNTER_PATH, "0\n")
            print("[switchberry-eth0-fixup] eth0 PHY is attached; no recovery needed.")
            return
        time.sleep(1)

    try:
        attempts = int(read_text(str(ETH0_FIX_COUNTER_PATH)) or "0")
    except ValueError:
        attempts = 0
    if attempts >= 4:
        raise ControlError("eth0 PHY recovery failed after four safe-mux reboot attempts")

    gpioset = first_executable(("/usr/bin/gpioset", "/usr/local/bin/gpioset"))
    if gpioset is None:
        raise ControlError("gpioset is required for eth0 PHY recovery")
    for settings in (("10=1", "11=0"), ("16=0",), ("6=0", "7=0"), ("13=1",)):
        result = run([gpioset, "-t", "0", "-c", "gpiochip2", *settings], timeout=5)
        if not result["ok"]:
            raise ControlError(result["stderr"] or "Unable to set the safe CM4 PPS mux state")

    attempts += 1
    ETH0_FIX_COUNTER_PATH.parent.mkdir(parents=True, exist_ok=True, mode=0o755)
    atomic_write_text(ETH0_FIX_COUNTER_PATH, f"{attempts}\n")
    unit = f"switchberry-eth0-recovery-{int(time.time())}"
    result = run(
        [
            "/usr/bin/systemd-run",
            f"--unit={unit}",
            "--collect",
            "--no-block",
            "--on-active=2s",
            "/usr/bin/systemctl",
            "reboot",
        ],
        timeout=8,
    )
    if not result["ok"]:
        raise ControlError(result["stderr"] or result["stdout"] or "Unable to queue PHY recovery reboot")
    print(f"[switchberry-eth0-fixup] eth0 has no attached PHY; queued safe-mux recovery reboot {attempts}/4.")


def command_sanity() -> None:
    require_root()
    missing: list[str] = []
    for _attempt in range(20):
        plane = active_switch_plane()
        required = [
            pathlib.Path("/dev/spidev7.0"),
            pathlib.Path("/dev/ttyAMA5"),
        ]
        if plane == "TC":
            required.append(pathlib.Path("/dev/spidev0.0"))
        elif plane == "DSA":
            required.extend(pathlib.Path(f"/sys/class/net/{name}") for name in FRONT_PORT_INTERFACES.values())
        missing = [str(path) for path in required if not path.exists()]
        if gpio_expander_device() is None:
            missing.append("/sys/bus/i2c/devices/*-0023")
        if plane == "DSA" and ksz_ptp_device() is None:
            missing.append("KSZ9567 DSA hardware clock (custom PTP-enabled kernel required)")
        if plane != "UNKNOWN" and not missing:
            return
        time.sleep(1)
    if active_switch_plane() == "UNKNOWN":
        raise ControlError("Neither the transparent-clock nor DSA switch plane is available")
    raise ControlError("Missing Switchberry prerequisites: " + ", ".join(missing))


def command_require_tc_plane() -> None:
    require_root()
    if active_switch_plane() != "TC":
        raise SystemExit(1)


def command_configure() -> None:
    require_root()
    normalized, warnings = normalize_config(read_stdin_json())
    backup = backup_config()
    atomic_write_config(normalized)
    boot_backup = configure_boot_plane(desired_switch_plane(normalized))
    reboot_required = get_clock_plane(normalized)["reboot_required"]
    unit = None if reboot_required else queue_apply()
    message = (
        "Configuration saved; reboot is required to activate the selected switch plane"
        if reboot_required
        else "Configuration saved; the Switchberry timing stack is applying it in the background"
    )
    emit(
        {
            "ok": True,
            "message": message,
            "backup": backup,
            "boot_backup": boot_backup,
            "unit": unit,
            "reboot_required": reboot_required,
            "warnings": warnings,
            "config": normalized,
        }
    )


def command_validate() -> None:
    normalized, warnings = normalize_config(read_stdin_json())
    emit({"ok": True, "message": "Configuration is valid", "warnings": warnings, "config": normalized})


def command_port(action: str, port: int) -> None:
    require_root()
    if action not in {"enable", "disable"}:
        raise ControlError("Port action must be enable or disable")
    if port not in range(1, 6):
        raise ControlError("Port must be between 1 and 5")
    if active_switch_plane() == "DSA":
        interface = FRONT_PORT_INTERFACES[port]
        state = "up" if action == "enable" else "down"
        result = run(["/usr/sbin/ip", "link", "set", "dev", interface, state], timeout=4)
        if not result["ok"]:
            result = run(["/sbin/ip", "link", "set", "dev", interface, state], timeout=4)
        if not result["ok"]:
            raise ControlError(result["stderr"] or result["stdout"] or "DSA port action failed")
        emit({"ok": True, "message": f"Front-panel port {port} {action}d", "interface": interface})

    value = 0x1300 if action == "enable" else 0x0C00
    ksz_write(port_register(port, 0x100), value, 2)
    emit({"ok": True, "message": f"Front-panel port {port} {action}d", "register": f"0x{port_register(port, 0x100):04X}"})


def command_restart() -> None:
    require_root()
    config = read_json(CONFIG_PATH)
    if get_clock_plane(config)["reboot_required"]:
        raise ControlError("A reboot is required before the selected PTP mode can be applied")
    unit = queue_apply()
    emit({"ok": True, "message": "Switchberry timing stack restart queued", "unit": unit})


def command_reboot() -> None:
    require_root()
    result = run(
        [
            "/usr/bin/systemd-run",
            "--unit=raspap-switchberry-reboot",
            "--collect",
            "--no-block",
            "--on-active=2s",
            "/usr/bin/systemctl",
            "reboot",
        ],
        timeout=8,
    )
    if not result["ok"]:
        raise ControlError(result["stderr"] or result["stdout"] or "Unable to queue reboot")
    emit({"ok": True, "message": "Switchberry reboot queued"})


def command_apply() -> None:
    require_root()
    sequence = (
        "switchberry-apply-network.service",
        "switchberry-apply-timing.service",
        "switchberry-full-init.service",
        "switchberry-ptp-role.service",
    )
    failures: list[str] = []
    for service in sequence:
        exists = run(["/usr/bin/systemctl", "show", "-p", "LoadState", "--value", service], timeout=4)
        if exists["stdout"] == "not-found":
            continue
        result = run(["/usr/bin/systemctl", "restart", service], timeout=120)
        if not result["ok"]:
            failures.append(f"{service}: {result['stderr'] or result['stdout']}")
    if failures:
        print("\n".join(failures), file=sys.stderr)
        raise SystemExit(1)


def main() -> None:
    parser = argparse.ArgumentParser(description="RaspAP Switchberry hardware controller")
    subparsers = parser.add_subparsers(dest="command", required=True)
    subparsers.add_parser("status", help="Return hardware and timing status as JSON")
    subparsers.add_parser("validate", help="Validate JSON configuration from stdin")
    subparsers.add_parser("configure", help="Validate, save, and apply JSON configuration from stdin")
    subparsers.add_parser("restart", help="Restart the Switchberry timing stack asynchronously")
    subparsers.add_parser("reboot", help="Reboot to activate a different Switchberry clock plane")
    subparsers.add_parser("_apply", help=argparse.SUPPRESS)
    subparsers.add_parser("_apply-timing", help=argparse.SUPPRESS)
    subparsers.add_parser("_eth0-fixup", help=argparse.SUPPRESS)
    subparsers.add_parser("_role-apply", help=argparse.SUPPRESS)
    subparsers.add_parser("_sanity", help=argparse.SUPPRESS)
    subparsers.add_parser("_require-tc-plane", help=argparse.SUPPRESS)
    port_parser = subparsers.add_parser("port", help="Enable or disable a front-panel port")
    port_parser.add_argument("action", choices=("enable", "disable"))
    port_parser.add_argument("port", type=int, choices=range(1, 6))
    clockmatrix_parser = subparsers.add_parser("clockmatrix", help="Control a ClockMatrix channel operating state")
    clockmatrix_parser.add_argument("channel", type=int, choices=(5, 6))
    clockmatrix_parser.add_argument("action", choices=tuple(sorted(CLOCKMATRIX_ACTIONS)))
    gnss_parser = subparsers.add_parser("gnss", help="Control the GNSS receiver and data services")
    gnss_parser.add_argument("action", choices=tuple(sorted(GNSS_ACTIONS)))
    args = parser.parse_args()

    try:
        if args.command == "status":
            emit(status_payload())
        if args.command == "validate":
            command_validate()
        if args.command == "configure":
            command_configure()
        if args.command == "port":
            command_port(args.action, args.port)
        if args.command == "clockmatrix":
            command_clockmatrix(args.channel, args.action)
        if args.command == "gnss":
            command_gnss(args.action)
        if args.command == "restart":
            command_restart()
        if args.command == "reboot":
            command_reboot()
        if args.command == "_apply":
            command_apply()
        if args.command == "_apply-timing":
            command_apply_timing()
        if args.command == "_eth0-fixup":
            command_eth0_fixup()
        if args.command == "_role-apply":
            command_role_apply()
        if args.command == "_sanity":
            command_sanity()
        if args.command == "_require-tc-plane":
            command_require_tc_plane()
    except ControlError as exc:
        emit({"ok": False, "error": str(exc)}, exit_code=2)


if __name__ == "__main__":
    main()
