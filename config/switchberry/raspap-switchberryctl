def normalize_clockmatrix(raw: Any) -> dict[str, Any]:
    defaults = default_clockmatrix_config()
    if raw is None:
        return defaults
    if not isinstance(raw, dict):
        raise ControlError("clockmatrix must be an object")
    raw_channels = raw.get("channels", [])
    if not isinstance(raw_channels, list):
        raise ControlError("clockmatrix.channels must be an array")
    by_channel: dict[int, dict[str, Any]] = {}
    for item in raw_channels:
        if not isinstance(item, dict):
            raise ControlError("Each ClockMatrix channel setting must be an object")
        channel = int_value(item.get("channel"), "clockmatrix.channels.channel", 5, 6)
        if channel not in {5, 6}:
            raise ControlError("ClockMatrix settings are available only for channels 5 and 6")
        if channel in by_channel:
            raise ControlError("ClockMatrix channel settings must be unique")
        by_channel[channel] = item

    normalized: list[dict[str, Any]] = []
    defaults_by_channel = {item["channel"]: item for item in defaults["channels"]}
    for channel in (5, 6):
        fallback = defaults_by_channel[channel]
        item = by_channel.get(channel, {})
        raw_unit = str(item.get("loop_bandwidth_unit", fallback["loop_bandwidth_unit"])).strip().lower()
        if raw_unit not in CLOCKMATRIX_BANDWIDTH_UNITS:
            raise ControlError("ClockMatrix loop bandwidth unit must be uHz, mHz, Hz, or kHz")
        normalized.append(
            {
                "channel": channel,
                "override_tuning": bool_value(
                    item.get("override_tuning", fallback["override_tuning"]),
                    f"clockmatrix.channel{channel}.override_tuning",
                ),
                "loop_bandwidth_value": int_value(
                    item.get("loop_bandwidth_value", fallback["loop_bandwidth_value"]),
                    f"clockmatrix.channel{channel}.loop_bandwidth_value",
                    0,
                    16383,
                ),
                "loop_bandwidth_unit": CLOCKMATRIX_BANDWIDTH_UNITS[raw_unit],
                "phase_slope_limit_ns_per_s": int_value(
                    item.get("phase_slope_limit_ns_per_s", fallback["phase_slope_limit_ns_per_s"]),
                    f"clockmatrix.channel{channel}.phase_slope_limit_ns_per_s",
                    0,
                    65535,
                ),
                "damping_factor": int_value(
                    item.get("damping_factor", fallback["damping_factor"]),
                    f"clockmatrix.channel{channel}.damping_factor",
                    0,
                    7,
                ),
                "combo_mode": enum_value(
                    item.get("combo_mode", fallback["combo_mode"]),
                    CLOCKMATRIX_COMBO_MODES,
                    f"clockmatrix.channel{channel}.combo_mode",
                ),
            }
        )

    if all(item["combo_mode"] == "FOLLOW_OTHER" for item in normalized):
        raise ControlError("ClockMatrix channels 5 and 6 cannot follow each other at the same time")
    return {"channels": normalized}


