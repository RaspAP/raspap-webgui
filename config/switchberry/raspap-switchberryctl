def get_ublox_configuration() -> dict[str, Any]:
    ubxtool = shutil.which("ubxtool")
    if ubxtool is None:
        return {"available": False, "status": "ubxtool is unavailable"}
    keys = [
        "CFG-NAVSPG-DYNMODEL",
        "CFG-RATE-MEAS",
        "CFG-RATE-NAV",
        "CFG-NAVSPG-INFIL_MINELEV",
        *GNSS_CONSTELLATION_KEYS.values(),
        "CFG-TP-TP1_ENA",
        "CFG-TP-PERIOD_TP1",
        "CFG-TP-PERIOD_LOCK_TP1",
        "CFG-TP-LEN_TP1",
        "CFG-TP-LEN_LOCK_TP1",
        "CFG-TP-ALIGN_TO_TOW_TP1",
        "CFG-TP-TIMEGRID_TP1",
    ]
    command = [ubxtool, "-P", UBLOX_PROTOCOL_VERSION]
    for key in keys:
        command.extend(("-g", f"{key},0"))
    command.extend(("-w", "0.5", "-v", "2"))
    query = run(command, timeout=4)
    rf_query = run(
        [ubxtool, "-P", UBLOX_PROTOCOL_VERSION, "-p", "MON-RF", "-w", "1", "-v", "2"],
        timeout=4,
    )
    values = {
        match.group(1): int(match.group(2))
        for match in re.finditer(r"item\s+(CFG-[A-Z0-9_-]+)/0x[0-9a-fA-F]+\s+val\s+(-?\d+)", query["stdout"])
    }
    if not values:
        return {
            "available": False,
            "status": query["stderr"] or "Receiver configuration did not respond",
        }
    dynamic_value = values.get("CFG-NAVSPG-DYNMODEL")
    dynamic_name = next(
        (name for name, value in GNSS_DYNAMIC_MODELS.items() if value == dynamic_value),
        "UNKNOWN",
    )
    constellation_values = {
        name: bool(values.get(key)) if key in values else None
        for name, key in GNSS_CONSTELLATION_KEYS.items()
    }
    rf_names = re.search(
        r"jammingState\s+\(([^)]+)\)\s+antStatus\s+\(([^)]+)\)\s+antPower\s+\(([^)]+)\)",
        rf_query["stdout"],
    )
    rf_values = re.search(r"noisePerMS\s+(\d+)\s+agcCnt\s+(\d+)\s+jamInd\s+(\d+)", rf_query["stdout"])
    jamming_indicator = int(rf_values.group(3)) if rf_values else None
    interference_level = (
        "Low" if jamming_indicator is not None and jamming_indicator < 64
        else "Moderate" if jamming_indicator is not None and jamming_indicator < 128
        else "High" if jamming_indicator is not None
        else "Unknown"
    )
    timegrid_names = {0: "UTC", 1: "GPS", 2: "GLONASS", 3: "BeiDou", 4: "Galileo", 5: "NavIC"}
    return {
        "available": True,
        "dynamic_model": dynamic_name,
        "dynamic_model_value": dynamic_value,
        "measurement_rate_ms": values.get("CFG-RATE-MEAS"),
        "navigation_rate_cycles": values.get("CFG-RATE-NAV"),
        "minimum_elevation_deg": values.get("CFG-NAVSPG-INFIL_MINELEV"),
        "constellations": constellation_values,
        "rf": {
            "jamming_state": rf_names.group(1) if rf_names else "Unknown",
            "antenna_status": rf_names.group(2) if rf_names else "Unknown",
            "antenna_power": rf_names.group(3) if rf_names else "Unknown",
            "noise_per_ms": int(rf_values.group(1)) if rf_values else None,
            "agc_count": int(rf_values.group(2)) if rf_values else None,
            "jamming_indicator": jamming_indicator,
            "interference_level": interference_level,
        },
        "timepulse": {
            "enabled": bool(values.get("CFG-TP-TP1_ENA")),
            "period_us": values.get("CFG-TP-PERIOD_TP1"),
            "locked_period_us": values.get("CFG-TP-PERIOD_LOCK_TP1"),
            "pulse_length_us": values.get("CFG-TP-LEN_TP1"),
            "locked_pulse_length_us": values.get("CFG-TP-LEN_LOCK_TP1"),
            "align_to_tow": bool(values.get("CFG-TP-ALIGN_TO_TOW_TP1")),
            "time_grid": timegrid_names.get(values.get("CFG-TP-TIMEGRID_TP1"), "Unknown"),
        },
    }


def get_gnss(config: dict[str, Any]) -> dict[str, Any]:
    source = config.get("gps", {}) if isinstance(config.get("gps"), dict) else {}
    configured = bool(source.get("present", False))
    applied_state = read_json(GNSS_APPLIED_STATE_PATH)
    applied = applied_state.get("fingerprint") == gnss_config_fingerprint(config)
    result: dict[str, Any] = {
        "configured": configured,
        "source_role": source.get("role"),
        "source_priority": source.get("priority"),
        "fix": False,
        "online": False,
        "mode": 0,
        "mode_label": "Offline",
        "satellites": [],
        "satellites_visible": 0,
        "satellites_used": 0,
        "pps_present": pathlib.Path("/dev/pps0").exists(),
        "device_present": pathlib.Path("/dev/ttyAMA5").exists(),
        "gpsd_active": run(["/usr/bin/systemctl", "is-active", "gpsd.service"], timeout=3)["stdout"] == "active",
        "bridge_active": run(["/usr/bin/systemctl", "is-active", "gpspipe-socat.service"], timeout=3)["stdout"] == "active",
        "applied": applied,
        "last_applied_at": applied_state.get("applied_at"),
        "receiver_configuration": {"available": False, "status": "Receiver offline"},
    }
    gpspipe = shutil.which("gpspipe")
    if gpspipe is None:
        result["status"] = "gpspipe is unavailable"
        result["guidance"] = "Install gpsd-clients to monitor the receiver."
        return result
    output = run([gpspipe, "-w", "-n", "6"], timeout=2.5)
    latest: dict[str, dict[str, Any]] = {}
    device: dict[str, Any] = {}
    for line in output["stdout"].splitlines():
        try:
            packet = json.loads(line)
        except (json.JSONDecodeError, TypeError):
            continue
        packet_class = str(packet.get("class", ""))
        if packet_class:
            latest[packet_class] = packet
        if packet_class == "DEVICES" and packet.get("devices"):
            candidate = packet["devices"][0]
            if isinstance(candidate, dict):
                device = candidate
        elif packet_class == "DEVICE":
            device = packet

    tpv = latest.get("TPV", {})
    sky = latest.get("SKY", {})
    gst = latest.get("GST", {})
    mode = int(tpv.get("mode", 0) or 0)
    mode_labels = {0: "Unknown", 1: "No fix", 2: "2D fix", 3: "3D fix"}
    satellites: list[dict[str, Any]] = []
    constellation_names = {
        0: "GPS",
        1: "SBAS",
        2: "Galileo",
        3: "BeiDou",
        4: "IMES",
        5: "QZSS",
        6: "GLONASS",
        7: "NavIC",
    }
    for satellite in sky.get("satellites", []):
        if not isinstance(satellite, dict):
            continue
        gnssid = satellite.get("gnssid")
        constellation = constellation_names.get(gnssid, "GNSS")
        satellites.append(
            {
                "prn": satellite.get("PRN"),
                "svid": satellite.get("svid", satellite.get("PRN")),
                "gnssid": gnssid,
                "constellation": constellation,
                "elevation": satellite.get("el"),
                "azimuth": satellite.get("az"),
                "signal_dbhz": satellite.get("ss"),
                "used": bool(satellite.get("used", False)),
                "health": satellite.get("health"),
            }
        )
    satellites.sort(
        key=lambda item: (
            not item["used"],
            -(float(item["signal_dbhz"]) if isinstance(item["signal_dbhz"], (int, float)) else -1),
        )
    )
    counts: dict[str, dict[str, int]] = {}
    for satellite in satellites:
        constellation = satellite["constellation"]
        counts.setdefault(constellation, {"visible": 0, "used": 0})
        counts[constellation]["visible"] += 1
        counts[constellation]["used"] += 1 if satellite["used"] else 0

    receiver_time = tpv.get("time") or sky.get("time")
    time_stale = False
    if isinstance(receiver_time, str):
        try:
            parsed_time = dt.datetime.fromisoformat(receiver_time.replace("Z", "+00:00"))
            time_stale = abs((dt.datetime.now(dt.timezone.utc) - parsed_time).total_seconds()) > 21_600
        except ValueError:
            time_stale = True
    device_details = str(device.get("subtype1", ""))
    model_match = re.search(r"(?:^|,)MOD=([^,]+)", device_details)
    firmware_match = re.search(r"(?:^|,)FWVER=([^,]+)", device_details)
    protocol_match = re.search(r"(?:^|,)PROTVER=([^,]+)", device_details)
    model_name = model_match.group(1) if model_match else None
    firmware_name = firmware_match.group(1) if firmware_match else None
    result.update(
        {
            "online": bool(device) or bool(latest),
            "fix": mode >= 2,
            "mode": mode,
            "mode_label": mode_labels.get(mode, f"Mode {mode}"),
            "time": receiver_time,
            "time_stale": time_stale,
            "latitude": tpv.get("lat"),
            "longitude": tpv.get("lon"),
            "altitude": tpv.get("altHAE", tpv.get("alt")),
            "speed_mps": tpv.get("speed"),
            "track_deg": tpv.get("track"),
            "climb_mps": tpv.get("climb"),
            "position_error_m": tpv.get("epx"),
            "vertical_error_m": tpv.get("epv"),
            "time_error_s": tpv.get("ept"),
            "dop": {
                "gdop": sky.get("gdop"),
                "pdop": sky.get("pdop"),
                "hdop": sky.get("hdop"),
                "vdop": sky.get("vdop"),
                "tdop": sky.get("tdop"),
                "xdop": sky.get("xdop"),
                "ydop": sky.get("ydop"),
            },
            "gst": {
                "rms": gst.get("rms"),
                "major": gst.get("major"),
                "minor": gst.get("minor"),
                "orientation": gst.get("orient"),
                "latitude_error": gst.get("lat"),
                "longitude_error": gst.get("lon"),
                "altitude_error": gst.get("alt"),
            },
            "satellites": satellites,
            "satellites_visible": int(sky.get("nSat", len(satellites)) or 0),
            "satellites_used": int(sky.get("uSat", sum(1 for item in satellites if item["used"])) or 0),
            "constellations": counts,
            "device": {
                "path": device.get("path", "/dev/ttyAMA5"),
                "driver": device.get("driver"),
                "subtype": device.get("subtype"),
                "details": device_details,
                "model": model_name,
                "firmware": firmware_name,
                "protocol": protocol_match.group(1) if protocol_match else None,
                "model_firmware": " · ".join(item for item in (model_name, firmware_name) if item),
                "baud": device.get("bps"),
                "cycle_seconds": device.get("cycle"),
            },
        }
    )
    result["receiver_configuration"] = get_ublox_configuration() if result["online"] else result["receiver_configuration"]
    if not result["online"]:
        result["status"] = output["stderr"] or "GNSS receiver offline"
        result["guidance"] = "Check gpsd, the M.2 receiver, and /dev/ttyAMA5."
    elif result["fix"]:
        result["status"] = result["mode_label"]
        result["guidance"] = "Navigation and receiver time are valid."
    elif result["satellites_visible"] == 0:
        result["status"] = "No satellites visible"
        antenna = result["receiver_configuration"].get("rf", {}).get("antenna_status")
        result["guidance"] = (
            "The active antenna is powered and electrically healthy; give it a clear view of the sky."
            if antenna == "OK"
            else "Check the GNSS antenna connection and give it a clear view of the sky."
        )
    else:
        result["status"] = "Acquiring satellites"
        result["guidance"] = "Receiver is online and collecting satellites; allow time for acquisition."
    if not configured:
        result["source_notice"] = "Receiver monitoring is active, but GNSS is not enabled as a ClockMatrix reference."
    return result


